  "raw_html": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>森林物语 · 绿叶诗笺</title>\n  <!-- Google Fonts: 手写感 + 清秀宋体 -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Ma+Shan+Zheng&family=Noto+Serif+SC:wght@400;600;700;900&family=ZCOOL+XiaoWei&display=swap\" rel=\"stylesheet\">\n  <style>\n    /* ===== 重置 & 基础 ===== */\n    * {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n    }\n\n    body {\n      background: #1e3c2c; /* 深林底色 */\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      min-height: 100vh;\n      font-family: 'Noto Serif SC', 'ZCOOL XiaoWei', serif;\n    }\n\n    /* ===== 幻灯片容器 ===== */\n    .presentation {\n      width: 1280px;\n      height: 720px;\n      position: relative;\n      background: var(--color-bg);\n      border-radius: 32px 32px 28px 28px;\n      box-shadow: 0 30px 50px rgba(0, 20, 5, 0.7);\n      overflow: hidden;\n      /* 绿叶纹理背景 (细微) */\n      background-image: repeating-linear-gradient(45deg, rgba(80, 140, 70, 0.03) 0px, rgba(80, 140, 70, 0.03) 20px, transparent 20px, transparent 40px);\n    }\n\n    .slides-track {\n      width: 100%;\n      height: calc(100% - 50px); /* 留出页脚空间 */\n      position: relative;\n    }\n\n    .slide {\n      position: absolute;\n      top: 0;\n      left: 0;\n      width: 100%;\n      height: 100%;\n      padding: 40px 60px 30px 60px;\n      display: flex;\n      flex-direction: column;\n      opacity: 0;\n      transition: opacity 0.5s ease;\n      pointer-events: none;\n      background: var(--color-bg);\n    }\n    .slide.active {\n      opacity: 1;\n      pointer-events: auto;\n    }\n\n    /* ===== 页脚 (森林古诗词) ===== */\n    .slide-footer {\n      position: absolute;\n      bottom: 0;\n      left: 0;\n      width: 100%;\n      height: 50px;\n      background: var(--color-footer-bg);\n      border-top: 2px solid var(--color-leaf-dark);\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      padding: 0 40px;\n      font-family: 'Ma Shan Zheng', cursive;\n      font-size: 18px;\n      color: var(--color-footer-text);\n      letter-spacing: 2px;\n      backdrop-filter: blur(2px);\n      box-shadow: 0 -4px 12px rgba(30, 60, 30, 0.2);\n    }\n    .footer-poem {\n      display: flex;\n      align-items: center;\n      gap: 10px;\n    }\n    .footer-poem .leaf-icon {\n      display: inline-block;\n      font-size: 22px;\n      filter: drop-shadow(0 2px 4px rgba(0,30,0,0.3));\n    }\n    .page-num {\n      font-family: 'ZCOOL XiaoWei', serif;\n      font-size: 18px;\n      font-weight: 600;\n      background: var(--color-leaf-mid);\n      padding: 2px 16px;\n      border-radius: 40px;\n      color: #f5f9ec;\n      letter-spacing: 1px;\n      box-shadow: inset 0 -2px 0 rgba(0,0,0,0.1);\n    }\n\n    /* ===== CSS 变量 (森林色系) ===== */\n    :root {\n      /* 主色 */\n      --color-bg: #eaf5e2;           /* 嫩芽底色 */\n      --color-surface: #d4e8ca;      /* 浅叶 */\n      --color-primary: #2d6a4f;      /* 深松绿 */\n      --color-secondary: #40916c;    /* 苔藓绿 */\n      --color-accent: #74c69d;       /* 亮叶绿 */\n      --color-leaf-dark: #1b4332;    /* 墨绿 */\n      --color-leaf-mid: #2d6a4f;     /* 森林绿 */\n      --color-leaf-light: #95d5b2;   /* 新芽 */\n      --color-gold: #d4a373;         /* 树皮暖色 */\n      --color-text: #1e3c2c;         /* 深绿文字 */\n      --color-text-light: #3a5a40;   /* 柔和绿 */\n      --color-white-soft: #f8fdf3;\n      --color-footer-bg: #1b3b2b;\n      --color-footer-text: #cfe3cf;\n      /* 字体 */\n      --font-title: 'Ma Shan Zheng', cursive;\n      --font-sub: 'ZCOOL XiaoWei', serif;\n      --font-body: 'Noto Serif SC', serif;\n      --font-deco: 'Ma Shan Zheng', cursive;\n    }\n\n    /* ===== 绿叶装饰 (全局) ===== */\n    .leaf-deco {\n      position: absolute;\n      pointer-events: none;\n      opacity: 0.2;\n      font-size: 60px;\n      z-index: 1;\n    }\n    .leaf-deco-1 { top: 20px; right: 30px; transform: rotate(25deg); }\n    .leaf-deco-2 { bottom: 80px; left: 20px; transform: rotate(-15deg) scaleX(-1); }\n    .leaf-deco-3 { top: 50%; left: 90%; font-size: 80px; opacity: 0.15; }\n\n    /* 每个slide内部装饰 (额外) */\n    .slide::before {\n      content: \"🌿\";\n      position: absolute;\n      font-size: 120px;\n      opacity: 0.06;\n      bottom: 10px;\n      right: 20px;\n      transform: rotate(10deg);\n      z-index: 0;\n    }\n    .slide::after {\n      content: \"🍃\";\n      position: absolute;\n      font-size: 90px;\n      opacity: 0.07;\n      top: 10px;\n      left: 15px;\n      transform: rotate(-20deg);\n      z-index: 0;\n    }\n\n    /* ===== 封面 cover ===== */\n    .slide.cover {\n      justify-content: center;\n      align-items: center;\n      text-align: center;\n      background: linear-gradient(145deg, #d8edce 0%, #b7d7a8 100%);\n    }\n    .slide.cover h1 {\n      font-family: var(--font-title);\n      font-size: 88px;\n      color: #1b4332;\n      text-shadow: 4px 4px 0 #a3c99b;\n      letter-spacing: 6px;\n      margin-bottom: 16px;\n      position: relative;\n      z-index: 2;\n    }\n    .slide.cover .subtitle {\n      font-family: var(--font-sub);\n      font-size: 32px;\n      color: #2d6a4f;\n      background: rgba(255, 255, 240, 0.5);\n      padding: 8px 32px;\n      border-radius: 60px;\n      backdrop-filter: blur(2px);\n      margin-bottom: 30px;\n      border: 1px solid #95d5b2;\n    }\n    .slide.cover .date-badge {\n      font-family: var(--font-body);\n      font-size: 22px;\n      background: #2d6a4f;\n      color: #f0f7e6;\n      padding: 6px 28px;\n      border-radius: 40px;\n      box-shadow: 0 6px 0 #1b4332;\n      letter-spacing: 2px;\n    }\n    /* 封面额外绿叶 */\n    .cover-leaf {\n      position: absolute;\n      font-size: 100px;\n      opacity: 0.2;\n      z-index: 1;\n    }\n    .cover-leaf-left { left: 20px; bottom: 20px; transform: rotate(-10deg); }\n    .cover-leaf-right { right: 20px; top: 20px; transform: rotate(40deg) scaleX(-1); }\n\n    /* ===== 目录 toc ===== */\n    .slide.toc {\n      background: linear-gradient(120deg, #e2f0da, #cde2c0);\n    }\n    .slide.toc .page-title {\n      font-family: var(--font-title);\n      font-size: 52px;\n      color: #1b4332;\n      border-bottom: 4px solid #40916c;\n      padding-bottom: 8px;\n      margin-bottom: 30px;\n      display: inline-block;\n      letter-spacing: 4px;\n    }\n    .toc-list {\n      display: flex;\n      flex-direction: column;\n      gap: 18px;\n      margin-top: 10px;\n      font-size: 28px;\n      font-family: var(--font-sub);\n      color: #1e3c2c;\n    }\n    .toc-list span {\n      display: flex;\n      align-items: center;\n      gap: 16px;\n      background: rgba(255, 255, 245, 0.5);\n      padding: 8px 20px;\n      border-radius: 60px;\n      backdrop-filter: blur(2px);\n      border-left: 8px solid #40916c;\n      box-shadow: 0 4px 8px rgba(0,30,0,0.05);\n    }\n    .toc-list span::before {\n      content: \"🌱\";\n      font-size: 30px;\n    }\n\n    /* ===== 章节 section ===== */\n    .slide.section {\n      justify-content: center;\n      align-items: center;\n      text-align: center;\n      background: radial-gradient(circle at 20% 30%, #d0e6c0, #b1cf9e);\n    }\n    .slide.section .chapter-tag {\n      font-family: var(--font-deco);\n      font-size: 38px;\n      color: #1b4332;\n      background: #f5fbe9;\n      padding: 4px 30px;\n      border-radius: 50px;\n      display: inline-block;\n      margin-bottom: 10px;\n      border: 2px solid #74c69d;\n      box-shadow: 0 4px 0 #2d6a4f;\n    }\n    .slide.section h1 {\n      font-family: var(--font-title);\n      font-size: 76px;\n      color: #1b4332;\n      margin: 10px 0;\n      text-shadow: 2px 2px 0 #b7d7a8;\n    }\n    .slide.section .subtitle {\n      font-family: var(--font-sub);\n      font-size: 28px;\n      color: #2d6a4f;\n      background: rgba(255, 245, 220, 0.3);\n      padding: 6px 40px;\n      border-radius: 40px;\n      backdrop-filter: blur(2px);\n    }\n\n    /* ===== 内容 content ===== */\n    .slide.content {\n      background: #f0f7ea;\n    }\n    .slide.content .page-title {\n      font-family: var(--font-title);\n      font-size: 44px;\n      color: #1b4332;\n      border-left: 12px solid #40916c;\n      padding-left: 24px;\n      margin-bottom: 24px;\n      letter-spacing: 2px;\n    }\n    .page-content {\n      font-family: var(--font-body);\n      font-size: 24px;\n      line-height: 1.7;\n      color: #1e3c2c;\n      background: rgba(255, 255, 245, 0.5);\n      padding: 24px 30px;\n      border-radius: 40px;\n      backdrop-filter: blur(2px);\n      border: 1px solid #b7d7a8;\n      box-shadow: 0 8px 0 #cfe3cf;\n      flex: 1;\n      display: flex;\n      align-items: center;\n    }\n    .page-content::before {\n      content: \"🌲\";\n      font-size: 48px;\n      margin-right: 20px;\n      opacity: 0.6;\n    }\n\n    /* ===== 结尾 ending ===== */\n    .slide.ending {\n      justify-content: center;\n      align-items: center;\n      text-align: center;\n      background: linear-gradient(135deg, #cbe3bc, #aacf98);\n    }\n    .slide.ending h1 {\n      font-family: var(--font-title);\n      font-size: 72px;\n      color: #1b4332;\n      text-shadow: 3px 3px 0 #b7d7a8;\n      margin-bottom: 20px;\n    }\n    .slide.ending .ending-message {\n      font-family: var(--font-sub);\n      font-size: 34px;\n      color: #2d6a4f;\n      background: rgba(245, 250, 235, 0.6);\n      padding: 12px 40px;\n      border-radius: 80px;\n      backdrop-filter: blur(2px);\n      border: 2px solid #74c69d;\n    }\n\n    /* ===== 导航 ===== */\n    .nav-dots {\n      position: absolute;\n      bottom: 62px;\n      left: 50%;\n      transform: translateX(-50%);\n      display: flex;\n      gap: 14px;\n      z-index: 20;\n    }\n    .nav-dot {\n      width: 14px;\n      height: 14px;\n      border-radius: 50%;\n      background: #a3c99b;\n      border: 2px solid #2d6a4f;\n      cursor: pointer;\n      transition: 0.2s;\n      box-shadow: 0 2px 4px rgba(0,20,0,0.2);\n    }\n    .nav-dot.active {\n      background: #1b4332;\n      border-color: #d4e8ca;\n      transform: scale(1.25);\n      box-shadow: 0 0 0 3px #95d5b2;\n    }\n\n    .nav-arrows {\n      position: absolute;\n      bottom: 62px;\n      right: 120px;\n      display: flex;\n      gap: 10px;\n      z-index: 20;\n    }\n    .nav-arrow {\n      background: #2d6a4f;\n      color: #f0f7e6;\n      border: none;\n      width: 44px;\n      height: 44px;\n      border-radius: 50%;\n      font-size: 24px;\n      cursor: pointer;\n      transition: 0.2s;\n      box-shadow: 0 4px 0 #1b4332;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n    .nav-arrow:hover {\n      background: #40916c;\n      transform: translateY(-2px);\n      box-shadow: 0 6px 0 #1b4332;\n    }\n    .nav-arrow:active {\n      transform: translateY(2px);\n      box-shadow: 0 2px 0 #1b4332;\n    }\n\n    .page-indicator {\n      position: absolute;\n      bottom: 62px;\n      left: 120px;\n      font-family: 'ZCOOL XiaoWei', serif;\n      font-size: 20px;\n      color: #1b4332;\n      background: rgba(235, 245, 220, 0.7);\n      padding: 4px 20px;\n      border-radius: 40px;\n      backdrop-filter: blur(2px);\n      border: 1px solid #74c69d;\n      z-index: 20;\n    }\n\n    /* ===== 占位符样式 (保留) ===== */\n    .placeholder-demo {\n      display: none; /* 占位符仅用于模板，实际内容已填充示例 */\n    }\n  </style>\n</head>\n<body>\n<div class=\"presentation\">\n  <!-- 全局绿叶装饰 (额外) -->\n  <div class=\"leaf-deco leaf-deco-1\">🍃</div>\n  <div class=\"leaf-deco leaf-deco-2\">🌿</div>\n  <div class=\"leaf-deco leaf-deco-3\">🌱</div>\n\n  <div class=\"slides-track\">\n    <!-- ========== 占位符标记 (保留) ========== -->\n    {{SLIDES_CONTENT}}\n\n    <!-- ===== 封面 cover ===== -->\n    <div class=\"slide cover active\">\n      <div class=\"cover-leaf cover-leaf-left\">🌳</div>\n      <div class=\"cover-leaf cover-leaf-right\">🌲</div>\n      <h1>{{title}}</h1>\n      <div class=\"subtitle\">{{subtitle}}</div>\n      <div class=\"date-badge\">{{date_badge}}</div>\n      <!-- 示例填充 (演示) -->\n      <!-- 实际占位符保留，但为了展示，填充示例文字 -->\n      <h1 style=\"display:none;\">森林诗笺</h1>\n      <div class=\"subtitle\" style=\"display:none;\">绿叶低语 · 万物有灵</div>\n      <div class=\"date-badge\" style=\"display:none;\">🌿 2025 · 惊蛰</div>\n    </div>\n\n    <!-- ===== 目录 toc ===== -->\n    <div class=\"slide toc\">\n      <div class=\"page-title\">{{title}}</div>\n      <div class=\"toc-list\">{{toc_items}}</div>\n      <!-- 示例填充 -->\n      <div class=\"page-title\" style=\"display:none;\">目录 · 林间小径</div>\n      <div class=\"toc-list\" style=\"display:none;\">\n        <span> 晨光 · 松针上的露珠</span>\n        <span> 午后 · 蕨类与苔藓</span>\n        <span> 黄昏 · 鹿影深处</span>\n        <span> 星夜 · 年轮密语</span>\n      </div>\n    </div>\n\n    <!-- ===== 章节 section ===== -->\n    <div class=\"slide section\">\n      <div class=\"chapter-tag\">{{chapter_tag}}</div>\n      <h1>{{title}}</h1>\n      <p class=\"subtitle\">{{subtitle}}</p>\n      <!-- 示例填充 -->\n      <div class=\"chapter-tag\" style=\"display:none;\">第一章</div>\n      <h1 style=\"display:none;\">森林探险</h1>\n      <p class=\"subtitle\" style=\"display:none;\">🌲 踏入千年古木的领地</p>\n    </div>\n\n    <!-- ===== 内容 content ===== -->\n    <div class=\"slide content\">\n      <div class=\"page-title\">{{title}}</div>\n      <div class=\"page-content\">{{content}}</div>\n      <!-- 示例填充 -->\n      <div class=\"page-title\" style=\"display:none;\">苔藓与蕨类</div>\n      <div class=\"page-content\" style=\"display:none;\">在腐殖土与树根之间，苔藓编织出柔软的绿毯。蕨类卷曲的嫩芽像古老的密码，每一片叶子都记录着森林的呼吸。林隙漏下的光斑，是时间碎成的金箔……</div>\n    </div>\n\n    <!-- ===== 结尾 ending ===== -->\n    <div class=\"slide ending\">\n      <h1>{{title}}</h1>\n      <p class=\"ending-message\">{{message}}</p>\n      <!-- 示例填充 -->\n      <h1 style=\"display:none;\">感谢聆听</h1>\n      <p class=\"ending-message\" style=\"display:none;\">🍃 愿每片叶子都为你写诗</p>\n    </div>\n  </div>\n\n  <!-- 页脚 (固定) 森林古诗词 -->\n  <div class=\"slide-footer\">\n    <div class=\"footer-poem\">\n      <span class=\"leaf-icon\">🌿</span>\n      <span>「返景入深林，复照青苔上」</span>\n      <span class=\"leaf-icon\">🍂</span>\n    </div>\n    <span class=\"page-num\">1 / {{TOTAL_PAGES}}</span>\n  </div>\n\n  <!-- 导航 UI -->\n  <div class=\"nav-dots\">\n    <div class=\"nav-dot active\" data-index=\"0\"></div>\n    <div class=\"nav-dot\" data-index=\"1\"></div>\n    <div class=\"nav-dot\" data-index=\"2\"></div>\n    <div class=\"nav-dot\" data-index=\"3\"></div>\n    <div class=\"nav-dot\" data-index=\"4\"></div>\n  </div>\n  <div class=\"nav-arrows\">\n    <button class=\"nav-arrow\" id=\"prevArrow\">◀</button>\n    <button class=\"nav-arrow\" id=\"nextArrow\">▶</button>\n  </div>\n  <div class=\"page-indicator\">1 / {{TOTAL_PAGES}}</div>\n</div>\n\n<script>\n  (function() {\n    // ===== 幻灯片控制 =====\n    const slides = document.querySelectorAll('.slide');\n    const dots = document.querySelectorAll('.nav-dot');\n    const pageNum = document.querySelector('.page-num');\n    const pageIndicator = document.querySelector('.page-indicator');\n    const prevBtn = document.getElementById('prevArrow');\n    const nextBtn = document.getElementById('nextArrow');\n    let current = 0;\n    const total = slides.length; // 5\n\n    // 更新总页数占位符 (实际渲染时替换)\n    document.querySelectorAll('.page-num, .page-indicator').forEach(el => {\n      el.textContent = el.textContent.replace('{{TOTAL_PAGES}}', total);\n    });\n\n    function updateSlide(index) {\n      slides.forEach((s, i) => {\n        s.classList.toggle('active', i === index);\n      });\n      dots.forEach((d, i) => {\n        d.classList.toggle('active', i === index);\n      });\n      // 更新页码\n      const pageStr = `${index + 1} / ${total}`;\n      pageNum.textContent = pageStr;\n      pageIndicator.textContent = pageStr;\n      current = index;\n    }\n\n    function goPrev() {\n      const idx = (current - 1 + total) % total;\n      updateSlide(idx);\n    }\n    function goNext() {\n      const idx = (current + 1) % total;\n      updateSlide(idx);\n    }\n\n    // 事件绑定\n    prevBtn.addEventListener('click', goPrev);\n    nextBtn.addEventListener('click', goNext);\n    dots.forEach(dot => {\n      dot.addEventListener('click', function() {\n        const idx = parseInt(this.dataset.index, 10);\n        updateSlide(idx);\n      });\n    });\n\n    // 键盘支持\n    document.addEventListener('keydown', (e) => {\n      if (e.key === 'ArrowLeft') goPrev();\n      if (e.key === 'ArrowRight') goNext();\n    });\n\n    // 初始化\n    updateSlide(0);\n  })();\n</script>\n\n<!-- 说明：占位符 {{SLIDES_CONTENT}} 和 {{TOTAL_PAGES}} 已保留在结构中，\n     但为了演示，同时填充了示例内容 (display:none 的占位演示)。\n     实际使用时，替换 {{SLIDES_CONTENT}} 为完整 slide 列表，并更新 {{TOTAL_PAGES}} -->\n</body>\n</html>"
}