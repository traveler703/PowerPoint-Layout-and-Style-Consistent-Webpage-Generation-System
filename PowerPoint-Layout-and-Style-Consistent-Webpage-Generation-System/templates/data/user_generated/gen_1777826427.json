  "raw_html": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>深海蓝境 · 海洋主题演示</title>\n  <!-- Google Fonts -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap\" rel=\"stylesheet\">\n  <style>\n    * {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n    }\n\n    :root {\n      /* 深海蓝色调 */\n      --color-primary: #0b2b4a;\n      --color-secondary: #1a4b6d;\n      --color-accent: #3fa7d6;\n      --color-surface: #0d1f2e;\n      --color-text: #e1f0fa;\n      --color-text-dark: #b0d0e0;\n      --color-wave-light: #2b7a9c;\n      --color-wave-dark: #0a3a4a;\n      --color-coral: #ff7b6b;\n      --color-glow: #4fc3f7;\n      --color-card-bg: rgba(20, 60, 90, 0.6);\n      --color-overlay: rgba(0, 15, 30, 0.7);\n      --color-border: #2f6f8a;\n      /* 字体 */\n      --font-heading: 'Playfair Display', serif;\n      --font-body: 'Montserrat', sans-serif;\n      --font-size-h1: 3.2rem;\n      --font-size-h2: 2.2rem;\n      --font-size-body: 1.1rem;\n      --font-size-small: 0.9rem;\n    }\n\n    body {\n      background: #04121c;\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      min-height: 100vh;\n      font-family: var(--font-body);\n      color: var(--color-text);\n    }\n\n    /* 幻灯片容器 */\n    .presentation-container {\n      width: 1280px;\n      height: 720px;\n      position: relative;\n      background: var(--color-surface);\n      border-radius: 28px;\n      box-shadow: 0 20px 40px rgba(0,0,0,0.8), 0 0 0 2px #1f4b66 inset;\n      overflow: hidden;\n    }\n\n    .slides-track {\n      width: 100%;\n      height: 100%;\n      position: relative;\n    }\n\n    .slide {\n      position: absolute;\n      top: 0;\n      left: 0;\n      width: 100%;\n      height: 100%;\n      padding: 50px 60px 90px 60px;\n      display: flex;\n      flex-direction: column;\n      justify-content: center;\n      background: radial-gradient(circle at 20% 30%, #0f334a, #04121c);\n      overflow: hidden;\n      transition: opacity 0.3s;\n      opacity: 0;\n      pointer-events: none;\n    }\n\n    .slide.active {\n      opacity: 1;\n      pointer-events: auto;\n    }\n\n    /* 波浪装饰 (所有页面通用) */\n    .slide::before {\n      content: '';\n      position: absolute;\n      bottom: 0;\n      left: 0;\n      width: 200%;\n      height: 120px;\n      background: repeating-linear-gradient(\n        90deg,\n        transparent 0px,\n        transparent 40px,\n        rgba(63, 167, 214, 0.15) 40px,\n        rgba(63, 167, 214, 0.15) 80px\n      );\n      background-size: 80px 100%;\n      animation: waveMove 8s linear infinite;\n      opacity: 0.5;\n      pointer-events: none;\n      z-index: 0;\n    }\n\n    .slide::after {\n      content: '';\n      position: absolute;\n      bottom: 20px;\n      left: -10%;\n      width: 120%;\n      height: 50px;\n      background: radial-gradient(circle at 30% 100%, #1f6f8c, transparent 70%);\n      opacity: 0.3;\n      filter: blur(8px);\n      pointer-events: none;\n      z-index: 0;\n    }\n\n    @keyframes waveMove {\n      0% { transform: translateX(0); }\n      100% { transform: translateX(-50%); }\n    }\n\n    /* 海洋生物装饰 (浮动) */\n    .marine-icon {\n      position: absolute;\n      font-size: 2.8rem;\n      opacity: 0.25;\n      pointer-events: none;\n      z-index: 1;\n      animation: float 6s ease-in-out infinite;\n    }\n\n    @keyframes float {\n      0% { transform: translateY(0px) rotate(0deg); }\n      50% { transform: translateY(-20px) rotate(5deg); }\n      100% { transform: translateY(0px) rotate(0deg); }\n    }\n\n    .slide-footer {\n      position: absolute;\n      bottom: 20px;\n      left: 0;\n      width: 100%;\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      gap: 20px;\n      padding: 0 40px;\n      z-index: 20;\n      color: var(--color-text-dark);\n      font-size: var(--font-size-small);\n      letter-spacing: 1px;\n    }\n\n    .page-num {\n      background: rgba(0, 20, 40, 0.7);\n      backdrop-filter: blur(4px);\n      padding: 6px 18px;\n      border-radius: 40px;\n      border: 1px solid var(--color-border);\n      font-weight: 600;\n      color: var(--color-accent);\n    }\n\n    /* 导航UI */\n    .nav-dots {\n      display: flex;\n      gap: 12px;\n      align-items: center;\n    }\n\n    .nav-dot {\n      width: 12px;\n      height: 12px;\n      border-radius: 50%;\n      background: var(--color-text-dark);\n      opacity: 0.4;\n      cursor: pointer;\n      transition: 0.2s;\n      border: 1px solid transparent;\n    }\n\n    .nav-dot.active {\n      opacity: 1;\n      background: var(--color-accent);\n      box-shadow: 0 0 12px var(--color-glow);\n      border-color: white;\n    }\n\n    .nav-arrows {\n      display: flex;\n      gap: 10px;\n    }\n\n    .nav-arrow {\n      background: rgba(20, 60, 90, 0.6);\n      backdrop-filter: blur(4px);\n      border: 1px solid var(--color-border);\n      color: var(--color-text);\n      width: 36px;\n      height: 36px;\n      border-radius: 30px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      cursor: pointer;\n      font-size: 1.4rem;\n      transition: 0.2s;\n    }\n\n    .nav-arrow:hover {\n      background: var(--color-accent);\n      color: #04121c;\n      border-color: white;\n    }\n\n    .page-indicator {\n      font-weight: 600;\n      background: rgba(0, 20, 40, 0.5);\n      padding: 4px 16px;\n      border-radius: 30px;\n      border: 1px solid #2f6f8a;\n      font-size: 0.9rem;\n    }\n\n    /* 占位符通用样式 */\n    .slide h1, .slide .page-title, .chapter-tag, .subtitle, .date-badge, .toc-list, .page-content, .ending-message {\n      position: relative;\n      z-index: 5;\n    }\n\n    /* cover */\n    .slide.cover {\n      text-align: center;\n      justify-content: center;\n      align-items: center;\n    }\n\n    .slide.cover h1 {\n      font-family: var(--font-heading);\n      font-size: 4.8rem;\n      font-weight: 700;\n      color: white;\n      text-shadow: 0 8px 20px rgba(0,0,0,0.7);\n      letter-spacing: 2px;\n      margin-bottom: 20px;\n      background: linear-gradient(135deg, #c2e9ff, #7fc9f0);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      background-clip: text;\n    }\n\n    .slide.cover .subtitle {\n      font-size: 1.8rem;\n      color: var(--color-text-dark);\n      background: rgba(0,0,0,0.2);\n      padding: 8px 30px;\n      border-radius: 60px;\n      backdrop-filter: blur(2px);\n      border: 1px solid var(--color-accent);\n      margin-bottom: 30px;\n    }\n\n    .slide.cover .date-badge {\n      background: var(--color-card-bg);\n      padding: 8px 28px;\n      border-radius: 30px;\n      border: 1px solid var(--color-accent);\n      font-size: 1rem;\n      color: #b0e0ff;\n      backdrop-filter: blur(4px);\n    }\n\n    /* toc */\n    .slide.toc {\n      justify-content: flex-start;\n      padding-top: 80px;\n    }\n\n    .slide.toc .page-title {\n      font-family: var(--font-heading);\n      font-size: 2.8rem;\n      margin-bottom: 40px;\n      border-bottom: 2px solid var(--color-accent);\n      display: inline-block;\n      padding-bottom: 8px;\n      color: #c2e9ff;\n    }\n\n    .toc-list {\n      display: flex;\n      flex-direction: column;\n      gap: 18px;\n      font-size: 1.4rem;\n      background: rgba(0, 20, 40, 0.3);\n      backdrop-filter: blur(4px);\n      padding: 30px 40px;\n      border-radius: 40px;\n      border: 1px solid var(--color-border);\n      max-width: 70%;\n    }\n\n    .toc-list div {\n      display: flex;\n      align-items: center;\n      gap: 16px;\n      color: var(--color-text);\n      font-weight: 500;\n      border-bottom: 1px dashed #2f5f7a;\n      padding-bottom: 8px;\n    }\n\n    .toc-list div::before {\n      content: \"🐚\";\n      font-size: 1.8rem;\n    }\n\n    /* section */\n    .slide.section {\n      justify-content: center;\n      align-items: center;\n      text-align: center;\n    }\n\n    .slide.section .chapter-tag {\n      font-size: 1.2rem;\n      background: var(--color-accent);\n      color: #04121c;\n      padding: 6px 24px;\n      border-radius: 40px;\n      display: inline-block;\n      margin-bottom: 20px;\n      font-weight: 700;\n      letter-spacing: 2px;\n      box-shadow: 0 0 20px rgba(63, 167, 214, 0.5);\n    }\n\n    .slide.section h1 {\n      font-family: var(--font-heading);\n      font-size: 4rem;\n      color: white;\n      text-shadow: 0 4px 20px #00000080;\n      margin-bottom: 20px;\n    }\n\n    .slide.section .subtitle {\n      font-size: 1.4rem;\n      color: var(--color-text-dark);\n      max-width: 600px;\n      background: rgba(0,0,0,0.2);\n      padding: 10px 30px;\n      border-radius: 40px;\n      backdrop-filter: blur(2px);\n    }\n\n    /* content */\n    .slide.content {\n      justify-content: flex-start;\n      padding-top: 70px;\n    }\n\n    .slide.content .page-title {\n      font-family: var(--font-heading);\n      font-size: 2.6rem;\n      color: #c2e9ff;\n      margin-bottom: 30px;\n      border-left: 6px solid var(--color-accent);\n      padding-left: 20px;\n    }\n\n    .page-content {\n      background: var(--color-card-bg);\n      backdrop-filter: blur(6px);\n      padding: 30px 40px;\n      border-radius: 40px;\n      border: 1px solid var(--color-border);\n      font-size: 1.2rem;\n      line-height: 1.7;\n      max-width: 80%;\n      color: #d4ecf7;\n      box-shadow: 0 10px 30px rgba(0,0,0,0.5);\n    }\n\n    .page-content::before {\n      content: \"🐟  \";\n      font-size: 2rem;\n    }\n\n    /* ending */\n    .slide.ending {\n      justify-content: center;\n      align-items: center;\n      text-align: center;\n    }\n\n    .slide.ending h1 {\n      font-family: var(--font-heading);\n      font-size: 4rem;\n      color: white;\n      text-shadow: 0 0 30px #3fa7d6;\n      margin-bottom: 30px;\n    }\n\n    .ending-message {\n      font-size: 1.8rem;\n      background: rgba(0, 20, 40, 0.5);\n      backdrop-filter: blur(4px);\n      padding: 20px 50px;\n      border-radius: 80px;\n      border: 1px solid var(--color-accent);\n      color: #b0e0ff;\n    }\n\n    /* 装饰元素: 每个页面增加海洋生物 */\n    .slide .deco1 { top: 10%; left: 5%; }\n    .slide .deco2 { top: 60%; right: 5%; }\n    .slide .deco3 { bottom: 15%; left: 10%; }\n\n    /* 响应式占位符 */\n    {{SLIDES_CONTENT}}\n  </style>\n</head>\n<body>\n<div class=\"presentation-container\">\n  <div class=\"slides-track\">\n    <!-- 封面 -->\n    <div class=\"slide cover active\">\n      <div class=\"marine-icon deco1\">🐋</div>\n      <div class=\"marine-icon deco2\" style=\"animation-delay: 1.5s;\">🐙</div>\n      <div class=\"marine-icon deco3\" style=\"animation-delay: 3s;\">🪸</div>\n      <h1>{{title}}</h1>\n      <div class=\"subtitle\">{{subtitle}}</div>\n      <div class=\"date-badge\">{{date_badge}}</div>\n    </div>\n\n    <!-- 目录 -->\n    <div class=\"slide toc\">\n      <div class=\"marine-icon deco1\" style=\"font-size: 3.5rem;\">🐠</div>\n      <div class=\"marine-icon deco2\" style=\"animation-delay: 2s;\">🐡</div>\n      <div class=\"page-title\">{{title}}</div>\n      <div class=\"toc-list\">{{toc_items}}</div>\n    </div>\n\n    <!-- 章节 -->\n    <div class=\"slide section\">\n      <div class=\"marine-icon deco1\">🦈</div>\n      <div class=\"marine-icon deco2\" style=\"animation-delay: 1.2s;\">🐬</div>\n      <div class=\"chapter-tag\">{{chapter_tag}}</div>\n      <h1>{{title}}</h1>\n      <p class=\"subtitle\">{{subtitle}}</p>\n    </div>\n\n    <!-- 内容 -->\n    <div class=\"slide content\">\n      <div class=\"marine-icon deco1\">🐳</div>\n      <div class=\"marine-icon deco2\" style=\"animation-delay: 2.5s;\">🦀</div>\n      <div class=\"page-title\">{{title}}</div>\n      <div class=\"page-content\">{{content}}</div>\n    </div>\n\n    <!-- 结尾 -->\n    <div class=\"slide ending\">\n      <div class=\"marine-icon deco1\">🐚</div>\n      <div class=\"marine-icon deco2\" style=\"animation-delay: 1.8s;\">⭐</div>\n      <h1>{{title}}</h1>\n      <p class=\"ending-message\">{{message}}</p>\n    </div>\n  </div>\n\n  <!-- 页脚固定结构 -->\n  <div class=\"slide-footer\">\n    <div class=\"nav-dots\">\n      <span class=\"nav-dot active\" data-index=\"0\"></span>\n      <span class=\"nav-dot\" data-index=\"1\"></span>\n      <span class=\"nav-dot\" data-index=\"2\"></span>\n      <span class=\"nav-dot\" data-index=\"3\"></span>\n      <span class=\"nav-dot\" data-index=\"4\"></span>\n    </div>\n    <div class=\"nav-arrows\">\n      <span class=\"nav-arrow\" id=\"prevArrow\">←</span>\n      <span class=\"nav-arrow\" id=\"nextArrow\">→</span>\n    </div>\n    <span class=\"page-indicator\">1 / {{TOTAL_PAGES}}</span>\n  </div>\n</div>\n\n<script>\n  (function() {\n    const slides = document.querySelectorAll('.slide');\n    const dots = document.querySelectorAll('.nav-dot');\n    const prev = document.getElementById('prevArrow');\n    const next = document.getElementById('nextArrow');\n    const indicator = document.querySelector('.page-indicator');\n    let current = 0;\n    const total = slides.length; // 5\n\n    // 更新 indicator 显示总页数 (占位符替换)\n    if (indicator) {\n      indicator.textContent = (current + 1) + ' / ' + total;\n    }\n\n    function updateSlide(index) {\n      slides.forEach((s, i) => {\n        s.classList.toggle('active', i === index);\n      });\n      dots.forEach((d, i) => {\n        d.classList.toggle('active', i === index);\n      });\n      if (indicator) {\n        indicator.textContent = (index + 1) + ' / ' + total;\n      }\n      current = index;\n    }\n\n    dots.forEach(dot => {\n      dot.addEventListener('click', function() {\n        const idx = parseInt(this.dataset.index);\n        updateSlide(idx);\n      });\n    });\n\n    prev.addEventListener('click', function() {\n      const idx = (current - 1 + total) % total;\n      updateSlide(idx);\n    });\n\n    next.addEventListener('click', function() {\n      const idx = (current + 1) % total;\n      updateSlide(idx);\n    });\n\n    // 键盘支持\n    document.addEventListener('keydown', function(e) {\n      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {\n        next.click();\n      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {\n        prev.click();\n      }\n    });\n\n    // 初始化\n    updateSlide(0);\n  })();\n</script>\n</body>\n</html>"
}