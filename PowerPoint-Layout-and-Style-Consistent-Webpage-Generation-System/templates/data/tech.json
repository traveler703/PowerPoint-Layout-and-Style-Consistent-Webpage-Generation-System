{
  "template_id": "tech",
  "template_name": "科技风",
  "description": "科技风 - 深邃星空感的赛博朋克风格，适合技术演示和科技主题内容",
  "version": "1.0.0",
  "css_variables": {
    "color-primary": "#00ffff",
    "color-secondary": "#0088ff",
    "color-accent-cyan": "#00ffff",
    "color-accent-blue": "#0088ff",
    "color-accent-purple": "#a855f7",
    "color-accent-pink": "#ec4899",
    "color-background": "#0a0c14",
    "color-surface": "#1a2035",
    "color-text": "#e0e0e0",
    "color-text-muted": "#a0a0a0",
    "color-text-light": "#808080",
    "color-card": "#151a2d",
    "color-cover-bg": "#0a0c14",
    "color-hud": "#00ffff",
    "color-glow": "rgba(0, 255, 255, 0.3)",
    "font-body": "'Segoe UI', 'Microsoft YaHei', 'Helvetica Neue', Arial, sans-serif",
    "font-heading": "'Segoe UI', 'Microsoft YaHei', 'Helvetica Neue', Arial, sans-serif"
  },
  "page_types": {
    "cover": {
      "skeleton": "<div class=\"slide cover\"><div class=\"corner-decor top-left\"></div><div class=\"corner-decor top-right\"></div><div class=\"corner-decor bottom-left\"></div><div class=\"corner-decor bottom-right\"></div><div class=\"scan-line\"></div><div class=\"grid-bg\"></div><div class=\"particles\"><div class=\"particle p1\"></div><div class=\"particle p2\"></div><div class=\"particle p3\"></div><div class=\"particle p4\"></div><div class=\"particle p5\"></div></div><div class=\"title-box\"><h1 class=\"main-title\"><i class=\"fa-solid fa-rocket\"></i> {{title}}</h1><p class=\"subtitle\">{{subtitle}}</p><div class=\"meta-info\"><span class=\"meta-item\"><i class=\"fa-solid fa-calendar\"></i> {{date_badge}}</span></div></div><div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div></div>",
      "placeholders": [
        "title",
        "subtitle",
        "date_badge"
      ]
    },
    "content": {
      "skeleton": "<div class=\"slide content\"><div class=\"corner-decor top-left\"></div><div class=\"corner-decor top-right\"></div><div class=\"corner-decor bottom-left\"></div><div class=\"corner-decor bottom-right\"></div><div class=\"circuit-lines\"></div><div class=\"page-title\"><i class=\"fa-solid fa-microchip\" style=\"margin-right:10px;color:#00ffff\"></i>{{title}}</div><div class=\"page-content\">{{content}}</div><div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div></div>",
      "placeholders": [
        "title",
        "content"
      ]
    },
    "toc": {
      "skeleton": "<div class=\"slide toc\"><div class=\"corner-decor top-left\"></div><div class=\"corner-decor top-right\"></div><div class=\"corner-decor bottom-left\"></div><div class=\"corner-decor bottom-right\"></div><div class=\"hex-grid\"></div><div class=\"page-title\"><i class=\"fa-solid fa-list-ol\" style=\"margin-right:10px;color:#00ffff\"></i>{{title}}</div><div class=\"page-content\"><div class=\"toc-grid\">{{toc_items}}</div></div><div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div></div>",
      "placeholders": [
        "title",
        "toc_items"
      ]
    },
    "compare": {
      "skeleton": "<div class=\"slide compare\"><div class=\"corner-decor top-left\"></div><div class=\"corner-decor top-right\"></div><div class=\"corner-decor bottom-left\"></div><div class=\"corner-decor bottom-right\"></div><div class=\"glow-orb orb1\"></div><div class=\"glow-orb orb2\"></div><div class=\"page-title\"><i class=\"fa-solid fa-layer-group\" style=\"margin-right:10px;color:#00ffff\"></i>{{title}}</div><div class=\"page-content\"><div class=\"compare-grid\">{{items}}</div></div><div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div></div>",
      "placeholders": [
        "title",
        "items"
      ]
    },
    "chart": {
      "skeleton": "<div class=\"slide chart\"><div class=\"corner-decor top-left\"></div><div class=\"corner-decor top-right\"></div><div class=\"corner-decor bottom-left\"></div><div class=\"corner-decor bottom-right\"></div><div class=\"data-stream\"></div><div class=\"page-title\"><i class=\"fa-solid fa-chart-line\" style=\"margin-right:10px;color:#00ffff\"></i>{{title}}</div><div class=\"page-content\">{{content}}</div><div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div></div>",
      "placeholders": [
        "title",
        "content"
      ]
    },
    "timeline": {
      "skeleton": "<div class=\"slide timeline\"><div class=\"corner-decor top-left\"></div><div class=\"corner-decor top-right\"></div><div class=\"corner-decor bottom-left\"></div><div class=\"corner-decor bottom-right\"></div><div class=\"timeline-bg\"></div><div class=\"page-title\"><i class=\"fa-solid fa-clock\" style=\"margin-right:10px;color:#00ffff\"></i>{{title}}</div><div class=\"page-content\"><div class=\"timeline-container\"><div class=\"timeline-line\"></div>{{timeline_items}}</div></div><div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div></div>",
      "placeholders": [
        "title",
        "timeline_items"
      ]
    },
    "qa": {
      "skeleton": "<div class=\"slide qa\"><div class=\"corner-decor top-left\"></div><div class=\"corner-decor top-right\"></div><div class=\"corner-decor bottom-left\"></div><div class=\"corner-decor bottom-right\"></div><div class=\"circuit-board\"></div><div class=\"page-title\"><i class=\"fa-solid fa-robot\" style=\"margin-right:10px;color:#00ffff\"></i>{{title}}</div><div class=\"page-content\"><div class=\"qa-grid\">{{qa_items}}</div></div><div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div></div>",
      "placeholders": [
        "title",
        "qa_items"
      ]
    },
    "ending": {
      "skeleton": "<div class=\"slide ending\"><div class=\"corner-decor top-left\"></div><div class=\"corner-decor top-right\"></div><div class=\"corner-decor bottom-left\"></div><div class=\"corner-decor bottom-right\"></div><div class=\"stars-bg\"></div><div class=\"scan-effect\"></div><div class=\"ending-content\"><div class=\"glow-ring\"></div><h1><i class=\"fa-solid fa-handshake\"></i> {{title}}</h1><p>{{message}}</p></div><div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div></div>",
      "placeholders": [
        "title",
        "message"
      ]
    }
  },
  "raw_html": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>PPT Template - 科技风</title>\n    <script src=\"https://cdn.bootcdn.net/ajax/libs/Chart.js/4.4.1/chart.umd.js\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n    <style>\n        * { margin: 0; padding: 0; box-sizing: border-box; }\n        html { scroll-behavior: smooth; }\n        body { font-family: 'Segoe UI', 'Microsoft YaHei', 'Helvetica Neue', Arial, sans-serif; overflow: hidden; height: 100vh; background-color: #000; }\n\n        .slides-wrapper { width: 100vw; height: 100vh; overflow: hidden; position: relative; }\n        .slides-track { width: 100%; height: 100%; display: flex; transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1); }\n        .slide-container { width: 100vw; height: 100vh; flex-shrink: 0; display: flex; justify-content: center; align-items: center; }\n\n        .nav-dots { display: none; }\n        .nav-dot { width: 12px; height: 12px; border-radius: 2px; background: rgba(0, 255, 255, 0.3); cursor: pointer; transition: all 0.3s; border: 1px solid rgba(0, 255, 255, 0.5); }\n        .nav-dot:hover { background: rgba(0, 255, 255, 0.6); transform: scale(1.2); box-shadow: 0 0 10px rgba(0, 255, 255, 0.5); }\n        .nav-dot.active { background: #00ffff; box-shadow: 0 0 15px rgba(0, 255, 255, 0.8); }\n\n        .nav-arrows { position: absolute; bottom: 20px; right: 30px; display: flex; gap: 15px; z-index: 10; }\n        .nav-arrow { width: 44px; height: 44px; border-radius: 4px; background: rgba(0, 255, 255, 0.1); backdrop-filter: blur(10px); border: 2px solid rgba(0, 255, 255, 0.4); color: #00ffff; font-size: 16px; display: flex; justify-content: center; align-items: center; cursor: pointer; transition: all 0.3s; }\n        .nav-arrow:hover { background: rgba(0, 255, 255, 0.25); box-shadow: 0 0 20px rgba(0, 255, 255, 0.4); transform: scale(1.05); }\n        .nav-arrow.disabled { opacity: 0.3; cursor: not-allowed; }\n\n        .page-indicator { position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); color: rgba(0, 255, 255, 0.7); font-size: 14px; font-weight: 600; z-index: 10; font-family: 'Courier New', monospace; }\n        .page-indicator .current { color: #00ffff; font-size: 18px; text-shadow: 0 0 10px rgba(0, 255, 255, 0.8); }\n\n        .slide { width: 1280px; height: 720px; position: relative; overflow: hidden; transform-origin: center center; }\n        .slide-footer { position: absolute; bottom: 15px; left: 0; right: 0; text-align: center; z-index: 10; pointer-events: none; }\n        .slide-footer .page-num { color: rgba(0, 255, 255, 0.6); font-size: 13px; font-weight: 500; font-family: 'Courier New', monospace; }\n        \n        /* HUD风格边角装饰 */\n        .corner-decor { position: absolute; width: 50px; height: 50px; z-index: 15; }\n        .corner-decor.top-left { top: 15px; left: 15px; border-top: 3px solid #00ffff; border-left: 3px solid #00ffff; box-shadow: 0 0 15px rgba(0, 255, 255, 0.4) inset; }\n        .corner-decor.top-right { top: 15px; right: 15px; border-top: 3px solid #00ffff; border-right: 3px solid #00ffff; box-shadow: 0 0 15px rgba(0, 255, 255, 0.4) inset; }\n        .corner-decor.bottom-left { bottom: 15px; left: 15px; border-bottom: 3px solid #00ffff; border-left: 3px solid #00ffff; box-shadow: 0 0 15px rgba(0, 255, 255, 0.4) inset; }\n        .corner-decor.bottom-right { bottom: 15px; right: 15px; border-bottom: 3px solid #00ffff; border-right: 3px solid #00ffff; box-shadow: 0 0 15px rgba(0, 255, 255, 0.4) inset; }\n        \n        /* 封面页样式 */\n        .slide.cover { background: radial-gradient(circle at 30% 20%, #1a2035 0%, #0a0c14 50%, #050608 100%); }\n        .slide.cover .scan-line { position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, transparent, rgba(0, 255, 255, 0.3), transparent); animation: scan 3s linear infinite; z-index: 5; }\n        @keyframes scan { 0% { top: -4px; } 100% { top: 100%; } }\n        .slide.cover .grid-bg { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background-image: linear-gradient(rgba(0, 255, 255, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 255, 255, 0.03) 1px, transparent 1px); background-size: 60px 60px; z-index: 1; }\n        .slide.cover .particles { position: absolute; top: 0; left: 0; right: 0; bottom: 0; z-index: 2; }\n        .slide.cover .particle { position: absolute; width: 4px; height: 4px; background: #00ffff; border-radius: 50%; box-shadow: 0 0 10px #00ffff; animation: float 6s ease-in-out infinite; }\n        .slide.cover .particle.p1 { top: 20%; left: 15%; animation-delay: 0s; }\n        .slide.cover .particle.p2 { top: 60%; left: 75%; animation-delay: 1s; }\n        .slide.cover .particle.p3 { top: 35%; left: 85%; animation-delay: 2s; }\n        .slide.cover .particle.p4 { top: 75%; left: 25%; animation-delay: 3s; }\n        .slide.cover .particle.p5 { top: 15%; left: 60%; animation-delay: 4s; }\n        @keyframes float { 0%, 100% { opacity: 0.3; transform: translateY(0); } 50% { opacity: 1; transform: translateY(-20px); } }\n        .slide.cover .title-box { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; z-index: 10; }\n        .slide.cover .main-title { font-size: 64px; font-weight: 900; color: #00ffff; text-shadow: 0 0 20px rgba(0, 255, 255, 0.8), 0 0 40px rgba(0, 255, 255, 0.4); margin-bottom: 25px; letter-spacing: 4px; animation: glow-cyan 3s ease-in-out infinite; }\n        .slide.cover .main-title i { margin-right: 15px; }\n        @keyframes glow-cyan { 0%, 100% { text-shadow: 0 0 20px rgba(0, 255, 255, 0.8), 0 0 40px rgba(0, 255, 255, 0.4); } 50% { text-shadow: 0 0 40px rgba(0, 255, 255, 1), 0 0 80px rgba(0, 255, 255, 0.6); } }\n        .slide.cover .subtitle { font-size: 28px; color: #a0a0a0; margin-bottom: 40px; letter-spacing: 2px; }\n        .slide.cover .meta-info { display: flex; justify-content: center; gap: 30px; }\n        .slide.cover .meta-item { background: rgba(0, 255, 255, 0.1); border: 1px solid rgba(0, 255, 255, 0.3); padding: 12px 25px; border-radius: 4px; color: #00ffff; font-size: 16px; font-family: 'Courier New', monospace; }\n        .slide.cover .meta-item i { margin-right: 8px; }\n        \n        /* 内容页样式 */\n        .slide.content { background: radial-gradient(circle at 70% 30%, #1a2035 0%, #0a0c14 100%); }\n        .slide.content .circuit-lines { position: absolute; top: 0; left: 0; right: 0; bottom: 0; opacity: 0.1; background-image: linear-gradient(90deg, #00ffff 1px, transparent 1px), linear-gradient(#00ffff 1px, transparent 1px); background-size: 80px 80px; z-index: 1; }\n        .page-title { position: absolute; top: 40px; left: 60px; background: rgba(0, 255, 255, 0.1); border: 2px solid rgba(0, 255, 255, 0.4); border-left: 4px solid #00ffff; color: #00ffff; padding: 15px 30px; font-size: 32px; font-weight: 700; display: inline-block; box-shadow: 0 0 20px rgba(0, 255, 255, 0.2); z-index: 10; letter-spacing: 2px; }\n        .page-content { position: absolute; top: 130px; left: 60px; right: 60px; bottom: 60px; z-index: 5; font-size: 22px; line-height: 1.8; color: #c0c0d0; }\n        .page-content h2 { font-size: 28px; color: #00ffff; margin-bottom: 20px; border-bottom: 2px solid rgba(0, 255, 255, 0.3); padding-bottom: 10px; display: inline-block; }\n        .page-content p { font-size: 20px; line-height: 1.7; color: #d0d0e0; margin-bottom: 18px; }\n        .page-content ul { list-style: none; }\n        .page-content ul li { font-size: 20px; color: #c0c0d0; margin-bottom: 12px; padding-left: 30px; position: relative; }\n        .page-content ul li::before { content: ''; position: absolute; left: 0; top: 8px; width: 10px; height: 10px; background: #00ffff; box-shadow: 0 0 10px #00ffff; transform: rotate(45deg); }\n        \n        /* 目录页样式 */\n        .slide.toc { background: radial-gradient(circle at 50% 50%, #1a2035 0%, #0a0c14 100%); }\n        .slide.toc .hex-grid { position: absolute; top: 0; left: 0; right: 0; bottom: 0; opacity: 0.05; z-index: 1; }\n        .toc-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 20px; }\n        .toc-item { background: rgba(0, 255, 255, 0.05); border: 1px solid rgba(0, 255, 255, 0.2); border-radius: 4px; padding: 20px 25px; display: flex; align-items: center; gap: 20px; transition: all 0.3s; cursor: pointer; position: relative; overflow: hidden; }\n        .toc-item::before { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(0, 255, 255, 0.1), transparent); transition: left 0.5s; }\n        .toc-item:hover { background: rgba(0, 255, 255, 0.1); border-color: rgba(0, 255, 255, 0.5); box-shadow: 0 0 20px rgba(0, 255, 255, 0.2); transform: translateX(5px); }\n        .toc-item:hover::before { left: 100%; }\n        .toc-number { width: 50px; height: 50px; background: rgba(0, 255, 255, 0.15); border: 2px solid #00ffff; border-radius: 4px; display: flex; justify-content: center; align-items: center; font-size: 24px; font-weight: 900; color: #00ffff; font-family: 'Courier New', monospace; text-shadow: 0 0 10px rgba(0, 255, 255, 0.5); }\n        .toc-text h3 { font-size: 20px; color: #e0e0e0; margin-bottom: 5px; }\n        .toc-text p { font-size: 13px; color: #808080; }\n        \n        /* 对比页样式 */\n        .slide.compare { background: radial-gradient(circle at 20% 80%, #1a2035 0%, #0a0c14 100%); }\n        .slide.compare .glow-orb { position: absolute; border-radius: 50%; filter: blur(80px); z-index: 1; }\n        .slide.compare .glow-orb.orb1 { width: 300px; height: 300px; background: rgba(0, 136, 255, 0.2); top: -100px; left: -100px; }\n        .slide.compare .glow-orb.orb2 { width: 250px; height: 250px; background: rgba(168, 85, 247, 0.2); bottom: -80px; right: -80px; }\n        .compare-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 25px; margin-top: 15px; }\n        .compare-card { background: rgba(26, 32, 53, 0.95); border: 1px solid rgba(0, 255, 255, 0.3); border-radius: 8px; padding: 25px; text-align: center; box-shadow: 0 0 30px rgba(0, 255, 255, 0.1); transition: all 0.3s; }\n        .compare-card:hover { transform: translateY(-8px); box-shadow: 0 10px 40px rgba(0, 255, 255, 0.2); border-color: rgba(0, 255, 255, 0.6); }\n        .compare-card h3 { font-size: 24px; color: #00ffff; margin-bottom: 12px; }\n        .compare-card .tag { background: linear-gradient(135deg, rgba(0, 255, 255, 0.2), rgba(0, 136, 255, 0.2)); color: #00ffff; padding: 6px 16px; border-radius: 4px; font-size: 13px; display: inline-block; margin-bottom: 15px; border: 1px solid rgba(0, 255, 255, 0.3); }\n        .compare-card ul { list-style: none; text-align: left; }\n        .compare-card ul li { font-size: 15px; color: #a0a0a0; margin-bottom: 8px; padding-left: 22px; position: relative; }\n        .compare-card ul li::before { content: '>'; position: absolute; left: 0; color: #00ffff; font-weight: bold; font-family: 'Courier New', monospace; }\n        \n        /* 图表页样式 */\n        .slide.chart { background: radial-gradient(circle at 80% 20%, #1a2035 0%, #0a0c14 100%); }\n        .slide.chart .data-stream { position: absolute; top: 0; left: 0; right: 0; bottom: 0; opacity: 0.03; background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 255, 255, 0.5) 2px, rgba(0, 255, 255, 0.5) 4px); z-index: 1; animation: stream 2s linear infinite; }\n        @keyframes stream { 0% { background-position: 0 0; } 100% { background-position: 0 100px; } }\n        .chart-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; height: 100%; padding-top: 10px; }\n        .chart-left { display: flex; flex-direction: column; gap: 15px; }\n        .chart-box { background: rgba(26, 32, 53, 0.9); border: 1px solid rgba(0, 255, 255, 0.2); border-radius: 8px; padding: 20px; box-shadow: 0 0 20px rgba(0, 255, 255, 0.1); flex: 1; }\n        .chart-box h3 { font-size: 16px; color: #00ffff; margin-bottom: 12px; text-align: center; font-family: 'Courier New', monospace; }\n        .stat-cards { display: flex; flex-direction: column; gap: 12px; }\n        .stat-card { background: linear-gradient(135deg, rgba(0, 136, 255, 0.15), rgba(0, 255, 255, 0.1)); border-radius: 8px; padding: 18px; display: flex; align-items: center; gap: 15px; border: 1px solid rgba(0, 255, 255, 0.2); }\n        .stat-card .icon { font-size: 32px; color: #00ffff; }\n        .stat-card .text h4 { font-size: 16px; color: #e0e0e0; margin-bottom: 4px; }\n        .stat-card .text p { font-size: 13px; color: #00ffff; font-family: 'Courier New', monospace; }\n        \n        /* 时间线页样式 */\n        .slide.timeline { background: linear-gradient(135deg, #0a0c14 0%, #1a2035 50%, #0a0c14 100%); }\n        .slide.timeline .timeline-bg { position: absolute; top: 0; left: 0; right: 0; bottom: 0; opacity: 0.05; background-image: radial-gradient(circle, #00ffff 1px, transparent 1px); background-size: 40px 40px; z-index: 1; }\n        .timeline-container { position: relative; padding: 20px 0; }\n        .timeline-line { position: absolute; left: 50%; top: 0; bottom: 0; width: 3px; background: linear-gradient(to bottom, #00ffff, #0088ff, #a855f7, #ec4899); border-radius: 2px; transform: translateX(-50%); box-shadow: 0 0 15px rgba(0, 255, 255, 0.4); }\n        .timeline-item { display: flex; align-items: center; margin-bottom: 25px; position: relative; }\n        .timeline-item:nth-child(odd) { flex-direction: row-reverse; }\n        .timeline-content { width: 42%; background: rgba(26, 32, 53, 0.9); border: 1px solid rgba(0, 255, 255, 0.3); border-radius: 8px; padding: 20px; box-shadow: 0 0 20px rgba(0, 255, 255, 0.1); }\n        .timeline-content h3 { font-size: 20px; color: #00ffff; margin-bottom: 8px; }\n        .timeline-content p { font-size: 14px; color: #a0a0a0; line-height: 1.6; }\n        .timeline-dot { position: absolute; left: 50%; transform: translateX(-50%); width: 20px; height: 20px; background: #00ffff; border-radius: 50%; border: 4px solid #0a0c14; z-index: 5; box-shadow: 0 0 15px rgba(0, 255, 255, 0.8); }\n        \n        /* 问答页样式 */\n        .slide.qa { background: radial-gradient(circle at 50% 80%, #1a2035 0%, #0a0c14 100%); }\n        .slide.qa .circuit-board { position: absolute; top: 0; left: 0; right: 0; bottom: 0; opacity: 0.04; z-index: 1; }\n        .qa-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 15px; }\n        .qa-card { background: rgba(26, 32, 53, 0.95); border: 1px solid rgba(0, 255, 255, 0.2); border-radius: 8px; padding: 20px; box-shadow: 0 0 15px rgba(0, 255, 255, 0.08); }\n        .qa-card .question { font-size: 17px; color: #e0e0e0; font-weight: 600; margin-bottom: 12px; display: flex; align-items: flex-start; gap: 10px; }\n        .qa-card .question::before { content: 'Q'; background: linear-gradient(135deg, #00ffff, #0088ff); color: #0a0c14; width: 26px; height: 26px; border-radius: 4px; display: flex; justify-content: center; align-items: center; font-size: 14px; font-weight: 900; flex-shrink: 0; }\n        .qa-card .answer { font-size: 15px; color: #a0a0a0; line-height: 1.6; padding-left: 36px; }\n        .qa-card .answer::before { content: 'A:'; color: #00ffff; font-weight: 600; font-family: 'Courier New', monospace; margin-left: -36px; margin-right: 10px; }\n        \n        /* 结束页样式 */\n        .slide.ending { background: radial-gradient(circle at 50% 50%, #1a2035 0%, #0a0c14 50%, #050608 100%); }\n        .slide.ending .stars-bg { position: absolute; top: 0; left: 0; right: 0; bottom: 0; z-index: 1; }\n        .slide.ending .star { position: absolute; width: 3px; height: 3px; background: white; border-radius: 50%; animation: twinkle 2s infinite; }\n        @keyframes twinkle { 0%, 100% { opacity: 0.2; } 50% { opacity: 1; } }\n        .slide.ending .scan-effect { position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, transparent, rgba(0, 255, 255, 0.6), transparent); animation: scan 4s linear infinite; z-index: 5; }\n        .slide.ending .ending-content { text-align: center; padding-top: 120px; position: relative; z-index: 10; }\n        .slide.ending .glow-ring { position: absolute; top: 80px; left: 50%; transform: translateX(-50%); width: 200px; height: 200px; border: 3px solid rgba(0, 255, 255, 0.3); border-radius: 50%; animation: pulse-ring 2s ease-out infinite; z-index: 5; }\n        @keyframes pulse-ring { 0% { transform: translateX(-50%) scale(0.8); opacity: 1; } 100% { transform: translateX(-50%) scale(1.5); opacity: 0; } }\n        .slide.ending .ending-content h1 { font-size: 52px; color: #00ffff; margin-bottom: 20px; text-shadow: 0 0 30px rgba(0, 255, 255, 0.6); animation: glow-cyan 3s ease-in-out infinite; }\n        .slide.ending .ending-content h1 i { margin-right: 15px; }\n        .slide.ending .ending-content p { font-size: 22px; color: #a0a0a0; }\n\n        .slide.cover .nav-dot, .slide.timeline .nav-dot, .slide.ending .nav-dot { background: rgba(0, 255, 255, 0.3); border-color: rgba(0, 255, 255, 0.5); }\n        .slide.cover .nav-dot.active, .slide.timeline .nav-dot.active, .slide.ending .nav-dot.active { background: #00ffff; box-shadow: 0 0 15px rgba(0, 255, 255, 0.8); }\n    </style>\n</head>\n<body>\n    <div class=\"slides-wrapper\" id=\"slidesWrapper\">\n        <div class=\"slides-track\" id=\"slidesTrack\">\n            {{SLIDES_CONTENT}}\n        </div>\n    </div>\n\n    <div class=\"nav-dots\" id=\"navDots\"></div>\n    <div class=\"nav-arrows\">\n        <div class=\"nav-arrow\" id=\"prevBtn\" onclick=\"prevSlide()\">\n            <i class=\"fa-solid fa-chevron-left\"></i>\n        </div>\n        <div class=\"nav-arrow\" id=\"nextBtn\" onclick=\"nextSlide()\">\n            <i class=\"fa-solid fa-chevron-right\"></i>\n        </div>\n    </div>\n    <div class=\"page-indicator\" id=\"pageIndicator\" style=\"display:none\">\n        <span class=\"current\" id=\"currentPage\">1</span> / <span id=\"totalPages\">{{TOTAL_PAGES}}</span>\n    </div>\n\n    <script>\n        let currentSlide = 0;\n        let totalSlides = {{TOTAL_PAGES}};\n        const track = document.getElementById('slidesTrack');\n        const navDots = document.getElementById('navDots');\n        const currentPageEl = document.getElementById('currentPage');\n        const totalPagesEl = document.getElementById('totalPages');\n        const prevBtn = document.getElementById('prevBtn');\n        const nextBtn = document.getElementById('nextBtn');\n\n        function initNavigation() {\n            totalPagesEl.textContent = totalSlides;\n            for (let i = 0; i < totalSlides; i++) {\n                const dot = document.createElement('div');\n                dot.className = 'nav-dot' + (i === 0 ? ' active' : '');\n                dot.onclick = () => goToSlide(i);\n                navDots.appendChild(dot);\n            }\n        }\n\n        function goToSlide(index) {\n            currentSlide = Math.max(0, Math.min(index, totalSlides - 1));\n            updateSlide();\n        }\n\n        function nextSlide() {\n            if (currentSlide < totalSlides - 1) {\n                currentSlide++;\n                updateSlide();\n            }\n        }\n\n        function prevSlide() {\n            if (currentSlide > 0) {\n                currentSlide--;\n                updateSlide();\n            }\n        }\n\n        function updateSlide() {\n            track.style.transform = `translateX(-${currentSlide * 100}vw)`;\n            currentPageEl.textContent = currentSlide + 1;\n            document.querySelectorAll('.nav-dot').forEach((dot, i) => {\n                dot.classList.toggle('active', i === currentSlide);\n            });\n            prevBtn.classList.toggle('disabled', currentSlide === 0);\n            nextBtn.classList.toggle('disabled', currentSlide === totalSlides - 1);\n        }\n\n        document.addEventListener('keydown', (e) => {\n            if (e.key === 'ArrowRight' || e.key === 'ArrowDown' || e.key === ' ') {\n                e.preventDefault();\n                nextSlide();\n            } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {\n                e.preventDefault();\n                prevSlide();\n            }\n        });\n\n        let isScrolling = false;\n        document.addEventListener('wheel', (e) => {\n            if (isScrolling) return;\n            isScrolling = true;\n            if (e.deltaY > 0) nextSlide();\n            else prevSlide();\n            setTimeout(() => { isScrolling = false; }, 800);\n        }, { passive: true });\n\n        let touchStartY = 0;\n        document.addEventListener('touchstart', (e) => { touchStartY = e.touches[0].clientY; }, { passive: true });\n        document.addEventListener('touchend', (e) => {\n            const diff = touchStartY - e.changedTouches[0].clientY;\n            if (Math.abs(diff) > 50) {\n                if (diff > 0) nextSlide();\n                else prevSlide();\n            }\n        }, { passive: true });\n\n        function scaleSlides() {\n            document.querySelectorAll('.slide').forEach(slide => {\n                const container = slide.parentElement;\n                if (slide && container) {\n                    const scale = Math.min(container.offsetWidth / 1280, container.offsetHeight / 720);\n                    slide.style.transform = `scale(${scale})`;\n                }\n            });\n        }\n\n        initNavigation();\n        updateSlide();\n        window.addEventListener('resize', scaleSlides);\n        window.addEventListener('load', scaleSlides);\n    </script>\n</body>\n</html>",
