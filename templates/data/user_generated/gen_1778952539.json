  "raw_html": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>冬日雪景演示模板</title>\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700;900&family=Poppins:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\">\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            background: #0a1628;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            min-height: 100vh;\n            font-family: 'Poppins', 'Noto Sans SC', sans-serif;\n            overflow: hidden;\n        }\n\n        :root {\n            --color-primary: #60a5fa;\n            --color-secondary: #e0f2fe;\n            --color-background: #0f172a;\n            --color-surface: #1e293b;\n            --color-text: #f8fafc;\n            --color-text-muted: #94a3b8;\n            --color-card: #1e293b;\n            --font-body: 'Poppins', 'Noto Sans SC', sans-serif;\n            --font-heading: 'Poppins', 'Noto Sans SC', sans-serif;\n        }\n\n        .slides-wrapper {\n            width: 1280px;\n            height: 720px;\n            border-radius: 24px;\n            box-shadow: 0 30px 80px rgba(0, 0, 0, 0.7);\n            overflow: hidden;\n            position: relative;\n            background: var(--color-background);\n        }\n\n        .slides-track {\n            display: flex;\n            transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);\n            width: max-content;\n        }\n\n        /* ===== Slide 基础样式 ===== */\n        .slide {\n            width: 1280px;\n            height: 720px;\n            flex-shrink: 0;\n            position: relative;\n            overflow: hidden;\n            background: radial-gradient(ellipse at 20% 80%, #0b2a3e, #07101e);\n        }\n\n        /* 背景装饰：远山/森林剪影 */\n        .slide::before {\n            content: '🌲🌲🌲';\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            right: 0;\n            font-size: 100px;\n            letter-spacing: 40px;\n            color: #0a1a2b;\n            opacity: 0.3;\n            line-height: 1;\n            pointer-events: none;\n        }\n\n        .slide::after {\n            content: '';\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            right: 0;\n            height: 120px;\n            background: linear-gradient(to top, #0a1a2b 0%, transparent 100%);\n            pointer-events: none;\n        }\n\n        /* ===== 雪花动画 ===== */\n        .snowflake {\n            position: absolute;\n            top: -60px;\n            color: #ffffff;\n            font-size: 1.6rem;\n            opacity: 0.7;\n            animation: fall linear infinite;\n            pointer-events: none;\n            z-index: 10;\n            text-shadow: 0 0 8px rgba(255, 255, 255, 0.3);\n        }\n\n        @keyframes fall {\n            0% {\n                transform: translateY(-60px) translateX(0) rotate(0deg);\n                opacity: 0;\n            }\n            10% {\n                opacity: 0.9;\n            }\n            90% {\n                opacity: 0.8;\n            }\n            100% {\n                transform: translateY(780px) translateX(80px) rotate(360deg);\n                opacity: 0;\n            }\n        }\n\n        /* 冰晶装饰（静态） */\n        .ice-crystal {\n            position: absolute;\n            color: rgba(255, 255, 255, 0.05);\n            font-size: 180px;\n            pointer-events: none;\n            transform: rotate(15deg);\n        }\n\n        /* ===== 通用组件定位 ===== */\n        .page-title {\n            position: absolute;\n            top: 40px;\n            left: 60px;\n            font-family: 'Noto Sans SC', sans-serif;\n            font-weight: 700;\n            font-size: 1.4rem;\n            color: var(--color-primary);\n            letter-spacing: 2px;\n            z-index: 5;\n        }\n\n        .page-content {\n            position: absolute;\n            top: 130px;\n            left: 60px;\n            right: 60px;\n            bottom: 60px;\n            z-index: 5;\n            overflow-y: auto;\n        }\n\n        .slide-footer {\n            position: absolute;\n            bottom: 20px;\n            right: 60px;\n            z-index: 5;\n            font-size: 0.85rem;\n            color: var(--color-text-muted);\n            font-weight: 300;\n            letter-spacing: 1px;\n        }\n\n        .page-num {\n            display: inline-block;\n            padding: 4px 16px;\n            border: 1px solid rgba(148, 163, 184, 0.2);\n            border-radius: 20px;\n            backdrop-filter: blur(4px);\n            background: rgba(15, 23, 42, 0.4);\n        }\n\n        /* ===== Cover 封面页 ===== */\n        .cover {\n            display: block;\n        }\n        .cover .main-title {\n            position: absolute;\n            top: 200px;\n            left: 80px;\n            font-size: 5rem;\n            font-weight: 900;\n            color: #ffffff;\n            text-shadow: 0 0 40px rgba(96, 165, 250, 0.3);\n            line-height: 1.2;\n            z-index: 5;\n        }\n        .cover .main-title span {\n            display: inline-block;\n            background: linear-gradient(135deg, #e0f2fe, #60a5fa);\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n        }\n        .cover .subtitle {\n            position: absolute;\n            top: 400px;\n            left: 80px;\n            font-size: 1.5rem;\n            font-weight: 300;\n            color: var(--color-secondary);\n            letter-spacing: 4px;\n            z-index: 5;\n        }\n        .cover .date-badge {\n            position: absolute;\n            bottom: 80px;\n            left: 80px;\n            padding: 8px 28px;\n            background: rgba(96, 165, 250, 0.15);\n            border: 1px solid rgba(96, 165, 250, 0.3);\n            border-radius: 30px;\n            color: var(--color-primary);\n            font-weight: 500;\n            font-size: 0.9rem;\n            backdrop-filter: blur(4px);\n            z-index: 5;\n        }\n        .cover .slide-footer {\n            bottom: 20px;\n        }\n\n        /* ===== TOC 目录页 ===== */\n        .toc .page-content {\n            display: block;\n        }\n        .toc-item {\n            display: flex;\n            align-items: center;\n            gap: 24px;\n            padding: 20px 0;\n            border-bottom: 1px solid rgba(148, 163, 184, 0.1);\n            color: var(--color-text);\n            font-size: 1.25rem;\n            font-weight: 400;\n        }\n        .toc-item:last-child {\n            border-bottom: none;\n        }\n        .toc-num {\n            font-family: 'Poppins', sans-serif;\n            font-weight: 700;\n            font-size: 1.6rem;\n            color: var(--color-primary);\n            min-width: 50px;\n        }\n\n        /* ===== Section 章节页 ===== */\n        .section .page-title {\n            top: 120px;\n            left: 100px;\n            font-size: 1rem;\n            font-weight: 500;\n            color: var(--color-text-muted);\n            letter-spacing: 6px;\n            text-transform: uppercase;\n        }\n        .section .section-title {\n            position: absolute;\n            top: 180px;\n            left: 100px;\n            font-size: 4.2rem;\n            font-weight: 900;\n            color: #ffffff;\n            line-height: 1.3;\n            z-index: 5;\n        }\n        .section .subtitle {\n            position: absolute;\n            top: 380px;\n            left: 100px;\n            font-size: 1.6rem;\n            font-weight: 300;\n            color: var(--color-secondary);\n            z-index: 5;\n        }\n        .section .ice-crystal {\n            bottom: -40px;\n            right: -40px;\n        }\n\n        /* ===== Content 内容页 ===== */\n        .content .page-title {\n            font-size: 2rem;\n            font-weight: 700;\n            color: #ffffff;\n        }\n        .content .page-content {\n            color: var(--color-text-muted);\n            font-size: 1.1rem;\n            line-height: 1.8;\n            font-weight: 300;\n        }\n        .content .ice-crystal {\n            bottom: 20px;\n            right: 20px;\n            font-size: 120px;\n        }\n\n        /* ===== Ending 结尾页 ===== */\n        .ending .ending-content {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            text-align: center;\n            z-index: 5;\n        }\n        .ending .ending-content h1 {\n            font-size: 4.5rem;\n            font-weight: 900;\n            color: #ffffff;\n            margin-bottom: 20px;\n            text-shadow: 0 0 60px rgba(96, 165, 250, 0.2);\n        }\n        .ending .ending-content .ending-message {\n            font-size: 1.4rem;\n            font-weight: 300;\n            color: var(--color-secondary);\n            letter-spacing: 2px;\n        }\n        .ending .ice-crystal {\n            top: 40px;\n            left: 60px;\n        }\n\n        /* ===== 导航系统 ===== */\n        .nav-dots {\n            position: fixed;\n            bottom: 40px;\n            left: 50%;\n            transform: translateX(-50%);\n            display: flex;\n            gap: 14px;\n            z-index: 100;\n        }\n        .nav-dot {\n            width: 12px;\n            height: 12px;\n            border-radius: 50%;\n            background: rgba(255, 255, 255, 0.2);\n            cursor: pointer;\n            transition: all 0.3s ease;\n            border: 1px solid rgba(255, 255, 255, 0.1);\n        }\n        .nav-dot.active {\n            background: var(--color-primary);\n            transform: scale(1.2);\n            box-shadow: 0 0 20px rgba(96, 165, 250, 0.4);\n            border-color: var(--color-primary);\n        }\n        .nav-dot:hover {\n            background: rgba(255, 255, 255, 0.5);\n        }\n\n        .nav-arrows {\n            position: fixed;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            width: 1280px;\n            display: flex;\n            justify-content: space-between;\n            padding: 0 20px;\n            z-index: 100;\n            pointer-events: none;\n        }\n        .nav-arrow {\n            width: 52px;\n            height: 52px;\n            border-radius: 50%;\n            background: rgba(15, 23, 42, 0.5);\n            backdrop-filter: blur(8px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            color: #ffffff;\n            font-size: 1.4rem;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            pointer-events: auto;\n        }\n        .nav-arrow:hover {\n            background: var(--color-primary);\n            border-color: var(--color-primary);\n            transform: scale(1.1);\n        }\n\n        .page-indicator {\n            position: fixed;\n            bottom: 38px;\n            right: 50px;\n            color: var(--color-text-muted);\n            font-size: 0.9rem;\n            font-weight: 300;\n            letter-spacing: 1px;\n            z-index: 100;\n            font-family: 'Poppins', sans-serif;\n        }\n        .page-indicator .current {\n            color: #ffffff;\n            font-weight: 600;\n            font-size: 1.1rem;\n        }\n\n        /* 滚动条样式 */\n        .page-content::-webkit-scrollbar {\n            width: 4px;\n        }\n        .page-content::-webkit-scrollbar-track {\n            background: transparent;\n        }\n        .page-content::-webkit-scrollbar-thumb {\n            background: var(--color-primary);\n            border-radius: 10px;\n        }\n    </style>\n</head>\n<body>\n\n    <div class=\"slides-wrapper\" id=\"slidesWrapper\">\n        <div class=\"slides-track\" id=\"slidesTrack\">\n\n            <!-- ========== Cover 封面页 ========== -->\n            <div class=\"slide cover\">\n                <div class=\"snowflake\" style=\"left:10%; animation-duration:12s; animation-delay:0s; font-size:1.2rem;\">❄️</div>\n                <div class=\"snowflake\" style=\"left:30%; animation-duration:15s; animation-delay:2s; font-size:2rem;\">❄️</div>\n                <div class=\"snowflake\" style=\"left:60%; animation-duration:10s; animation-delay:5s; font-size:1rem;\">❄️</div>\n                <div class=\"snowflake\" style=\"left:80%; animation-duration:18s; animation-delay:1s; font-size:1.8rem;\">❄️</div>\n                <div class=\"snowflake\" style=\"left:50%; animation-duration:14s; animation-delay:7s; font-size:1.4rem;\">❄️</div>\n\n                <h1 class=\"main-title\"><span>冬日雪景</span></h1>\n                <p class=\"subtitle\">❄️ 银装素裹的童话世界</p>\n                <div class=\"date-badge\">2025 · 冬</div>\n\n                <div class=\"slide-footer\"><span class=\"page-num\">1</span></div>\n            </div>\n\n            <!-- ========== TOC 目录页 ========== -->\n            <div class=\"slide toc\">\n                <div class=\"page-title\">{{title}}</div>\n                <div class=\"page-content\">\n                    <div class=\"toc-item\"><span class=\"toc-num\">01</span> 冬日序曲 · 初雪降临</div>\n                    <div class=\"toc-item\"><span class=\"toc-num\">02</span> 雪景之美 · 北国风光</div>\n                    <div class=\"toc-item\"><span class=\"toc-num\">03</span> 摄影技巧 · 记录瞬间</div>\n                    <div class=\"toc-item\"><span class=\"toc-num\">04</span> 温暖瞬间 · 围炉夜话</div>\n                </div>\n                <div class=\"slide-footer\"><span class=\"page-num\">2</span></div>\n            </div>\n\n            <!-- ========== Section 章节页 ========== -->\n            <div class=\"slide section\">\n                <div class=\"page-title\">{{chapter_tag}}</div>\n                <h1 class=\"section-title\">{{title}}</h1>\n                <p class=\"subtitle\">{{subtitle}}</p>\n                <div class=\"ice-crystal\">❄️</div>\n                <div class=\"slide-footer\"><span class=\"page-num\">3</span></div>\n            </div>\n\n            <!-- ========== Content 内容页 ========== -->\n            <div class=\"slide content\">\n                <div class=\"page-title\">{{title}}</div>\n                <div class=\"page-content\">{{content}}</div>\n                <div class=\"ice-crystal\">❄️</div>\n                <div class=\"slide-footer\"><span class=\"page-num\">4</span></div>\n            </div>\n\n            <!-- ========== Ending 结尾页 ========== -->\n            <div class=\"slide ending\">\n                <div class=\"snowflake\" style=\"left:15%; animation-duration:14s; animation-delay:0s; font-size:1.5rem;\">❄️</div>\n                <div class=\"snowflake\" style=\"left:45%; animation-duration:12s; animation-delay:4s; font-size:2.2rem;\">❄️</div>\n                <div class=\"snowflake\" style=\"left:75%; animation-duration:16s; animation-delay:2s; font-size:1.8rem;\">❄️</div>\n\n                <div class=\"ice-crystal\">❄️</div>\n                <div class=\"ending-content\">\n                    <h1>{{title}}</h1>\n                    <p class=\"ending-message\">{{message}}</p>\n                </div>\n                <div class=\"slide-footer\"><span class=\"page-num\">5</span></div>\n            </div>\n\n        </div>\n    </div>\n\n    <!-- ===== 导航点 (由 JS 动态生成) ===== -->\n    <div class=\"nav-dots\" id=\"navDots\"></div>\n\n    <!-- ===== 导航箭头 ===== -->\n    <div class=\"nav-arrows\">\n        <div class=\"nav-arrow\" id=\"prevBtn\" onclick=\"prevSlide()\">◀</div>\n        <div class=\"nav-arrow\" id=\"nextBtn\" onclick=\"nextSlide()\">▶</div>\n    </div>\n\n    <!-- ===== 页码指示器 ===== -->\n    <div class=\"page-indicator\">\n        <span class=\"current\" id=\"currentPage\">1</span> / <span id=\"totalPages\">5</span>\n    </div>\n\n    <script>\n        const slidesTrack = document.getElementById('slidesTrack');\n        const slides = document.querySelectorAll('.slide');\n        const totalSlides = slides.length;\n        let currentIndex = 0;\n\n        // 动态生成导航点\n        const navDots = document.getElementById('navDots');\n        for (let i = 0; i < totalSlides; i++) {\n            const dot = document.createElement('div');\n            dot.className = 'nav-dot' + (i === 0 ? ' active' : '');\n            dot.onclick = () => goToSlide(i);\n            navDots.appendChild(dot);\n        }\n\n        const dots = document.querySelectorAll('.nav-dot');\n        const currentPageSpan = document.getElementById('currentPage');\n\n        function goToSlide(index) {\n            if (index < 0 || index >= totalSlides) return;\n            currentIndex = index;\n            slidesTrack.style.transform = `translateX(-${currentIndex * 1280}px)`;\n\n            // 更新导航点状态\n            dots.forEach((dot, i) => {\n                dot.classList.toggle('active', i === currentIndex);\n            });\n\n            // 更新页码\n            currentPageSpan.textContent = currentIndex + 1;\n        }\n\n        function prevSlide() {\n            goToSlide(currentIndex - 1);\n        }\n\n        function nextSlide() {\n            goToSlide(currentIndex + 1);\n        }\n\n        // 键盘支持\n        document.addEventListener('keydown', (e) => {\n            if (e.key === 'ArrowLeft') prevSlide();\n            if (e.key === 'ArrowRight') nextSlide();\n        });\n\n        // 触摸滑动支持\n        let touchStartX = 0;\n        let touchEndX = 0;\n        document.addEventListener('touchstart', (e) => {\n            touchStartX = e.changedTouches[0].screenX;\n        });\n        document.addEventListener('touchend', (e) => {\n            touchEndX = e.changedTouches[0].screenX;\n            const diff = touchStartX - touchEndX;\n            if (Math.abs(diff) > 50) {\n                if (diff > 0) nextSlide();\n                else prevSlide();\n            }\n        });\n    </script>\n\n</body>\n</html>",
