{
  "template_id": "dunhuang_feitian",
  "template_name": "敦煌飞天",
  "description": "以敦煌飞天壁画为灵感，融合金红华丽色调与祥云纹样，营造典雅、神秘、富有文化底蕴的PPT模板。",
  "version": "1.0.0",
  "css_variables": {
    "color-primary": "#C43A31",
    "color-secondary": "#D4A849",
    "color-background": "#1A0F0A",
    "color-surface": "#2C1A12",
    "color-text": "#F5E6C8",
    "color-text-muted": "#B89B7A",
    "color-card": "#3D241B",
    "font-body": "Noto Serif SC",
    "font-heading": "ZCOOL XiaoWei",
    "color-accent-gold": "#E8C547",
    "color-accent-red": "#B83227",
    "color-accent-cloud": "#F0D9B5"
  },
  "page_types": {
    "cover": {
      "skeleton": "<div class=\"slide cover\">\n  <div class=\"cloud-motif top-left\"></div>\n  <div class=\"cloud-motif top-right\"></div>\n  <div class=\"cloud-motif bottom-left\"></div>\n  <div class=\"cloud-motif bottom-right\"></div>\n  <div class=\"feitian-figure left\"></div>\n  <div class=\"feitian-figure right\"></div>\n  <div class=\"golden-glow\"></div>\n  <div class=\"cover-content\">\n    <h1 class=\"main-title\">{{title}}</h1>\n    <p class=\"subtitle\">{{subtitle}}</p>\n  </div>\n  <div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div>\n</div>",
      "placeholders": [
        "title",
        "subtitle",
        "page_number"
      ]
    },
    "content": {
      "skeleton": "<div class=\"slide content\">\n  <div class=\"content-deco top-right\"></div>\n  <div class=\"content-deco bottom-left\"></div>\n  <div class=\"cloud-divider\"></div>\n  <div class=\"page-title-wrap\">\n    <h2 class=\"page-title\">{{title}}</h2>\n    <div class=\"title-underline\"></div>\n  </div>\n  <div class=\"page-content\">{{content}}</div>\n  <div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div>\n</div>",
      "placeholders": [
        "title",
        "content",
        "page_number"
      ]
    },
    "toc": {
      "skeleton": "<div class=\"slide toc\">\n  <div class=\"toc-deco left\"></div>\n  <div class=\"toc-deco right\"></div>\n  <div class=\"cloud-motif center\"></div>\n  <h2 class=\"page-title\">{{title}}</h2>\n  <div class=\"toc-list\">{{toc_items}}</div>\n  <div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div>\n</div>",
      "placeholders": [
        "title",
        "toc_items",
        "page_number"
      ]
    },
    "section": {
      "skeleton": "<div class=\"slide section\">\n  <div class=\"section-deco bg-shape\"></div>\n  <div class=\"cloud-motif top\"></div>\n  <div class=\"cloud-motif bottom\"></div>\n  <div class=\"section-center\">\n    <div class=\"section-number\">{{section_num}}</div>\n    <h1 class=\"section-title\">{{title}}</h1>\n    <p class=\"section-subtitle\">{{subtitle}}</p>\n  </div>\n  <div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div>\n</div>",
      "placeholders": [
        "title",
        "subtitle",
        "page_number"
      ]
    },
    "ending": {
      "skeleton": "<div class=\"slide ending\">\n  <div class=\"ending-deco circle-bg\"></div>\n  <div class=\"cloud-motif left\"></div>\n  <div class=\"cloud-motif right\"></div>\n  <div class=\"ending-content\">\n    <h1 class=\"ending-title\">{{title}}</h1>\n    <p class=\"ending-message\">{{message}}</p>\n  </div>\n  <div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div>\n</div>",
      "placeholders": [
        "title",
        "message",
        "page_number"
      ]
    },
    "compare": {
      "skeleton": "<div class=\"slide compare\">\n  <div class=\"compare-deco top\"></div>\n  <div class=\"cloud-motif left\"></div>\n  <div class=\"cloud-motif right\"></div>\n  <h2 class=\"page-title\">{{title}}</h2>\n  <div class=\"compare-items\">{{compare_items}}</div>\n  <div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div>\n</div>",
      "placeholders": [
        "title",
        "compare_items",
        "page_number"
      ]
    },
    "chart": {
      "skeleton": "<div class=\"slide chart\">\n  <div class=\"chart-deco\"></div>\n  <div class=\"cloud-motif top\"></div>\n  <h2 class=\"page-title\">{{title}}</h2>\n  <div class=\"chart-container\">{{chart_data}}</div>\n  <div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div>\n</div>",
      "placeholders": [
        "title",
        "chart_data",
        "page_number"
      ]
    },
    "timeline": {
      "skeleton": "<div class=\"slide timeline\">\n  <div class=\"timeline-deco\"></div>\n  <div class=\"cloud-motif left\"></div>\n  <div class=\"cloud-motif right\"></div>\n  <h2 class=\"page-title\">{{title}}</h2>\n  <div class=\"timeline-items\">{{timeline_items}}</div>\n  <div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div>\n</div>",
      "placeholders": [
        "title",
        "timeline_items",
        "page_number"
      ]
    },
    "qa": {
      "skeleton": "<div class=\"slide qa\">\n  <div class=\"qa-deco\"></div>\n  <div class=\"cloud-motif top\"></div>\n  <h2 class=\"page-title\">{{title}}</h2>\n  <div class=\"qa-items\">{{qa_items}}</div>\n  <div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div>\n</div>",
      "placeholders": [
        "title",
        "qa_items",
        "page_number"
      ]
    }
  },
  "tags": [
    "敦煌",
    "飞天",
    "中国风",
    "华丽",
    "典雅",
    "祥云",
    "金红"
  ],
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "raw_html": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>敦煌飞天</title>\n    <script src=\"https://cdn.bootcdn.net/ajax/libs/Chart.js/4.4.1/chart.umd.js\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&family=ZCOOL+XiaoWei&display=swap\" rel=\"stylesheet\">\n    <style>\n        /* ========== 通用基础 ========== */\n        * { margin: 0; padding: 0; box-sizing: border-box; }\n        html { scroll-behavior: smooth; }\n        body { overflow: hidden; height: 100vh; background: #1A0F0A; font-family: var(--font-body); }\n\n        .slides-wrapper { width: 100vw; height: 100vh; overflow: hidden; position: relative; }\n        .slides-track { width: 100%; height: 100%; display: flex; transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1); }\n        .slide-container { width: 100vw; height: 100vh; flex-shrink: 0; display: flex; justify-content: center; align-items: center; }\n\n        .slide { width: 1280px; height: 720px; position: relative; overflow: hidden; transform-origin: center center; }\n\n        .slide-footer { position: absolute; bottom: 18px; left: 0; right: 0; text-align: center; z-index: 10; }\n        .slide-footer .page-num { color: var(--color-text-muted); font-size: 13px; letter-spacing: 1px; font-family: var(--font-heading); }\n\n        .nav-dots { position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%); display: flex; gap: 10px; z-index: 20; }\n        .nav-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--nav-color, rgba(255,255,255,0.3)); cursor: pointer; transition: all 0.4s; border: 1px solid var(--nav-color, rgba(255,255,255,0.4)); }\n        .nav-dot:hover { background: var(--nav-color, rgba(255,255,255,0.6)); transform: scale(1.4); }\n        .nav-dot.active { background: var(--nav-active, #ffffff); border-color: var(--nav-active, #ffffff); box-shadow: 0 0 12px var(--nav-active, rgba(255,255,255,0.8)); }\n\n        .nav-arrows { position: absolute; bottom: 20px; right: 30px; display: flex; gap: 12px; z-index: 20; }\n        .nav-arrow { width: 42px; height: 42px; border-radius: 50%; background: var(--nav-bg, rgba(28,15,10,0.8)); backdrop-filter: blur(12px); border: 1px solid var(--nav-color, rgba(255,255,255,0.3)); color: var(--nav-color, rgba(255,255,255,0.8)); font-size: 14px; display: flex; justify-content: center; align-items: center; cursor: pointer; transition: all 0.3s; }\n        .nav-arrow:hover { background: var(--nav-bg-hover, rgba(255,255,255,0.15)); border-color: var(--nav-color, rgba(255,255,255,0.6)); box-shadow: 0 0 15px var(--nav-color, rgba(255,255,255,0.3)); transform: scale(1.08); }\n        .nav-arrow.disabled { opacity: 0.25; cursor: not-allowed; }\n\n        .page-indicator { position: absolute; bottom: 24px; left: 30px; color: var(--nav-color, rgba(255,255,255,0.5)); font-size: 13px; z-index: 20; letter-spacing: 2px; }\n        .page-indicator .current { color: var(--nav-active, #ffffff); font-size: 18px; }\n\n        /* 深色页面导航适配 */\n        .slide.cover .nav-dot, .slide.section .nav-dot, .slide.ending .nav-dot { background: var(--nav-light-color, rgba(255,255,255,0.3)); border-color: var(--nav-light-color, rgba(255,255,255,0.4)); }\n        .slide.cover .nav-dot.active, .slide.section .nav-dot.active, .slide.ending .nav-dot.active { background: var(--nav-light-active, #ffffff); border-color: var(--nav-light-active, #ffffff); box-shadow: 0 0 15px var(--nav-light-active, rgba(255,255,255,0.8)); }\n        .slide.cover .nav-arrow, .slide.section .nav-arrow, .slide.ending .nav-arrow { background: var(--nav-light-bg, rgba(0,0,0,0.6)); border-color: var(--nav-light-color, rgba(255,255,255,0.3)); color: var(--nav-light-active, #ffffff); }\n        .slide.cover .page-indicator, .slide.section .page-indicator, .slide.ending .page-indicator { color: var(--nav-light-color, rgba(255,255,255,0.5)); }\n        .slide.cover .page-indicator .current, .slide.section .page-indicator .current, .slide.ending .page-indicator .current { color: var(--nav-light-active, #ffffff); }\n        .slide.cover .slide-footer .page-num, .slide.section .slide-footer .page-num, .slide.ending .slide-footer .page-num { color: var(--nav-light-color, rgba(255,255,255,0.35)); }\n\n        /* ========== CSS 变量 ========== */\n        :root {\n            --color-primary: #C43A31;\n            --color-secondary: #D4A849;\n            --color-background: #1A0F0A;\n            --color-surface: #2C1A12;\n            --color-text: #F5E6C8;\n            --color-text-muted: #B89B7A;\n            --color-card: #3D241B;\n            --font-body: 'Noto Serif SC', serif;\n            --font-heading: 'ZCOOL XiaoWei', serif;\n            --color-accent-gold: #E8C547;\n            --color-accent-red: #B83227;\n            --color-accent-cloud: #F0D9B5;\n            --nav-color: #F5E6C8;\n            --nav-active: #C43A31;\n            --nav-bg: #1A0F0A;\n            --nav-bg-hover: #2C1A12;\n            --nav-light-color: rgba(255,255,255,0.5);\n            --nav-light-active: #ffffff;\n            --nav-light-bg: rgba(0,0,0,0.6);\n        }\n\n        /* ========== 动画 ========== */\n        @keyframes drift { 0%,100% { transform: translateX(0) translateY(0); opacity: 0.5; } 50% { transform: translateX(20px) translateY(-8px); opacity: 0.7; } }\n        @keyframes twinkle { 0%,100% { opacity: 0.2; } 50% { opacity: 0.8; } }\n        @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }\n        @keyframes glow { 0%,100% { opacity: 0.4; } 50% { opacity: 0.8; } }\n\n        /* ========== 页面样式 ========== */\n\n        /* ----- 封面页 ----- */\n        .slide.cover { background: radial-gradient(ellipse at 50% 40%, #D4A84933 0%, #1A0F0A 100%); }\n        .cloud-motif { position: absolute; width: 120px; height: 60px; background: radial-gradient(circle at 30% 50%, var(--color-accent-cloud) 0%, transparent 70%); opacity: 0.3; animation: drift 6s ease-in-out infinite; }\n        .cloud-motif.top-left { top: 40px; left: 40px; }\n        .cloud-motif.top-right { top: 40px; right: 40px; animation-delay: -2s; }\n        .cloud-motif.bottom-left { bottom: 80px; left: 40px; animation-delay: -4s; }\n        .cloud-motif.bottom-right { bottom: 80px; right: 40px; animation-delay: -1s; }\n        .cloud-motif.center { top: 50%; left: 50%; transform: translate(-50%, -50%); width: 200px; height: 100px; opacity: 0.2; }\n        .feitian-figure { position: absolute; width: 80px; height: 160px; background: linear-gradient(135deg, var(--color-accent-gold) 0%, var(--color-secondary) 100%); border-radius: 50% 50% 30% 30%; opacity: 0.15; animation: float 5s ease-in-out infinite; }\n        .feitian-figure.left { left: 80px; top: 40%; transform: rotate(-10deg); }\n        .feitian-figure.right { right: 80px; top: 40%; transform: rotate(10deg); animation-delay: -2.5s; }\n        .golden-glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 400px; height: 400px; background: radial-gradient(circle, var(--color-accent-gold) 0%, transparent 70%); opacity: 0.15; animation: glow 4s ease-in-out infinite; }\n        .cover-content { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; z-index: 5; }\n        .main-title { font-family: var(--font-heading); font-size: 64px; color: var(--color-accent-gold); text-shadow: 0 0 30px rgba(212,168,73,0.4); letter-spacing: 6px; margin-bottom: 20px; }\n        .subtitle { font-family: var(--font-body); font-size: 22px; color: var(--color-text); letter-spacing: 4px; font-weight: 300; }\n\n        /* ----- 内容页 ----- */\n        .slide.content { background: linear-gradient(160deg, #1A0F0A 0%, #2C1A12 50%, #1A0F0A 100%); }\n        .content-deco { position: absolute; width: 200px; height: 200px; border: 2px solid var(--color-accent-gold); opacity: 0.1; border-radius: 50%; }\n        .content-deco.top-right { top: -60px; right: -60px; }\n        .content-deco.bottom-left { bottom: -60px; left: -60px; }\n        .cloud-divider { position: absolute; top: 80px; left: 0; right: 0; height: 40px; background: linear-gradient(90deg, transparent, var(--color-accent-cloud), transparent); opacity: 0.1; }\n        .page-title-wrap { position: relative; margin-bottom: 30px; padding: 0 60px; }\n        .page-title { font-family: var(--font-heading); font-size: 36px; color: var(--color-accent-gold); letter-spacing: 4px; margin-bottom: 12px; }\n        .title-underline { width: 80px; height: 3px; background: var(--color-secondary); margin: 0 auto; }\n        .page-content { padding: 0 80px; color: var(--color-text); font-size: 18px; line-height: 1.8; text-align: justify; }\n\n        /* ----- 目录页 ----- */\n        .slide.toc { background: linear-gradient(160deg, #1A0F0A 0%, #2C1A12 50%, #1A0F0A 100%); }\n        .toc-deco { position: absolute; width: 300px; height: 300px; border: 1px solid var(--color-accent-gold); opacity: 0.08; border-radius: 50%; }\n        .toc-deco.left { top: 50%; left: -100px; transform: translateY(-50%); }\n        .toc-deco.right { top: 50%; right: -100px; transform: translateY(-50%); }\n        .toc-list { display: flex; flex-direction: column; align-items: center; gap: 16px; margin-top: 40px; padding: 0 100px; }\n        .toc-item { font-family: var(--font-body); font-size: 20px; color: var(--color-text); letter-spacing: 2px; padding: 8px 24px; border-left: 3px solid var(--color-secondary); transition: all 0.3s; cursor: default; }\n        .toc-item:hover { color: var(--color-accent-gold); border-left-color: var(--color-accent-gold); padding-left: 32px; }\n\n        /* ----- 章节页 ----- */\n        .slide.section { background: radial-gradient(ellipse at 50% 40%, #D4A84933 0%, #1A0F0A 100%); }\n        .section-deco.bg-shape { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 500px; height: 500px; border: 2px solid var(--color-accent-gold); opacity: 0.08; border-radius: 50%; }\n        .cloud-motif.top { top: 60px; left: 50%; transform: translateX(-50%); }\n        .cloud-motif.bottom { bottom: 80px; left: 50%; transform: translateX(-50%); animation-delay: -3s; }\n        .section-center { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; z-index: 5; }\n        .section-number { font-family: var(--font-heading); font-size: 48px; color: var(--color-accent-gold); opacity: 0.3; margin-bottom: 10px; }\n        .section-title { font-family: var(--font-heading); font-size: 52px; color: var(--color-accent-gold); letter-spacing: 6px; margin-bottom: 16px; }\n        .section-subtitle { font-family: var(--font-body); font-size: 22px; color: var(--color-text); letter-spacing: 3px; font-weight: 300; }\n\n        /* ----- 结束页 ----- */\n        .slide.ending { background: radial-gradient(ellipse at 50% 40%, #D4A84933 0%, #1A0F0A 100%); }\n        .ending-deco.circle-bg { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 400px; height: 400px; border: 2px solid var(--color-accent-gold); opacity: 0.1; border-radius: 50%; }\n        .cloud-motif.left { top: 30%; left: 40px; }\n        .cloud-motif.right { top: 30%; right: 40px; animation-delay: -2s; }\n        .ending-content { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); display: flex; flex-direction: column; align-items: center; text-align: center; z-index: 5; }\n        .ending-title { font-family: var(--font-heading); font-size: 56px; color: var(--color-accent-gold); letter-spacing: 6px; margin: 0 0 20px 0; }\n        .ending-message { font-family: var(--font-body); font-size: 24px; color: var(--color-text); letter-spacing: 3px; margin: 0; }\n\n        /* ----- 对比页 ----- */\n        .slide.compare { background: linear-gradient(160deg, #1A0F0A 0%, #2C1A12 50%, #1A0F0A 100%); }\n        .compare-deco.top { position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, transparent, var(--color-accent-gold), transparent); opacity: 0.3; }\n        .compare-items { display: flex; justify-content: center; gap: 60px; padding: 30px 80px; }\n        .compare-item { flex: 1; background: var(--color-card); border: 1px solid rgba(212,168,73,0.2); border-radius: 12px; padding: 30px; text-align: center; transition: all 0.3s; }\n        .compare-item:hover { border-color: var(--color-accent-gold); box-shadow: 0 0 20px rgba(212,168,73,0.15); }\n        .compare-item h3 { font-family: var(--font-heading); color: var(--color-accent-gold); font-size: 24px; margin-bottom: 12px; }\n        .compare-item p { color: var(--color-text); font-size: 16px; line-height: 1.6; }\n\n        /* ----- 图表页 ----- */\n        .slide.chart { background: linear-gradient(160deg, #1A0F0A 0%, #2C1A12 50%, #1A0F0A 100%); }\n        .chart-deco { position: absolute; bottom: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, transparent, var(--color-accent-gold), transparent); opacity: 0.3; }\n        .chart-container { padding: 20px 80px; height: 400px; }\n\n        /* ----- 时间线页 ----- */\n        .slide.timeline { background: linear-gradient(160deg, #1A0F0A 0%, #2C1A12 50%, #1A0F0A 100%); }\n        .timeline-deco { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 2px; height: 500px; background: linear-gradient(to bottom, transparent, var(--color-accent-gold), transparent); opacity: 0.2; }\n        .timeline-items { display: flex; flex-direction: column; gap: 20px; padding: 40px 100px; position: relative; z-index: 5; }\n        .timeline-item { display: flex; align-items: center; gap: 20px; padding: 16px 24px; background: var(--color-card); border-radius: 8px; border-left: 4px solid var(--color-secondary); transition: all 0.3s; }\n        .timeline-item:hover { border-left-color: var(--color-accent-gold); transform: translateX(8px); }\n        .timeline-item .year { font-family: var(--font-heading); font-size: 24px; color: var(--color-accent-gold); min-width: 80px; }\n        .timeline-item .desc { color: var(--color-text); font-size: 16px; }\n\n        /* ----- Q&A页 ----- */\n        .slide.qa { background: linear-gradient(160deg, #1A0F0A 0%, #2C1A12 50%, #1A0F0A 100%); }\n        .qa-deco { position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg, transparent, var(--color-accent-gold), transparent); opacity: 0.3; }\n        .qa-items { padding: 30px 80px; display: flex; flex-direction: column; gap: 20px; }\n        .qa-item { background: var(--color-card); border-radius: 10px; padding: 20px 28px; border: 1px solid rgba(212,168,73,0.15); }\n        .qa-item .question { font-family: var(--font-heading); font-size: 20px; color: var(--color-accent-gold); margin-bottom: 8px; }\n        .qa-item .answer { color: var(--color-text); font-size: 16px; line-height: 1.6; }\n    </style>\n</head>\n<body>\n    <div class=\"slides-wrapper\" id=\"slidesWrapper\">\n        <div class=\"slides-track\" id=\"slidesTrack\">\n            <!-- 导航按钮 -->\n            <div class=\"nav-arrow prev\" id=\"prevBtn\" onclick=\"prevSlide()\"><i class=\"fa-solid fa-chevron-left\"></i></div>\n            <div class=\"nav-arrow next\" id=\"nextBtn\" onclick=\"nextSlide()\"><i class=\"fa-solid fa-chevron-right\"></i></div>\n\n            <!-- {SLIDES_CONTENT} 占位符 -->\n            {SLIDES_CONTENT}\n        </div>\n    </div>\n\n    <div class=\"nav-dots\" id=\"navDots\"></div>\n    <div class=\"page-indicator\" id=\"pageIndicator\">\n        <span class=\"current\" id=\"currentPage\">1</span> / <span id=\"totalPages\">{TOTAL_PAGES}</span>\n    </div>\n\n    <script>\n        var currentSlide = 0;\n        var totalSlides = 5;\n        var track = document.getElementById(\"slidesTrack\");\n        var navDots = document.getElementById(\"navDots\");\n        var currentPageEl = document.getElementById(\"currentPage\");\n        var totalPagesEl = document.getElementById(\"totalPages\");\n\n        function initNavigation() {\n            totalPagesEl.textContent = totalSlides;\n            for (var i = 0; i < totalSlides; i++) {\n                var dot = document.createElement(\"div\");\n                dot.className = \"nav-dot\" + (i === 0 ? \" active\" : \"\");\n                dot.onclick = (function(idx) { return function() { goToSlide(idx); }; })(i);\n                navDots.appendChild(dot);\n            }\n        }\n\n        function goToSlide(index) {\n            currentSlide = Math.max(0, Math.min(index, totalSlides - 1));\n            updateSlide();\n        }\n\n        function nextSlide() { if (currentSlide < totalSlides - 1) { currentSlide++; updateSlide(); } }\n        function prevSlide() { if (currentSlide > 0) { currentSlide--; updateSlide(); } }\n\n        function updateSlide() {\n            track.style.transform = \"translateX(-\" + (currentSlide * 100) + \"vw)\";\n            currentPageEl.textContent = currentSlide + 1;\n            var dots = navDots.querySelectorAll(\".nav-dot\");\n            for (var i = 0; i < dots.length; i++) { dots[i].classList.toggle(\"active\", i === currentSlide); }\n        }\n\n        document.addEventListener(\"keydown\", function(e) {\n            if (e.key === \"ArrowRight\" || e.key === \"ArrowDown\" || e.key === \" \") { e.preventDefault(); nextSlide(); }\n            else if (e.key === \"ArrowLeft\" || e.key === \"ArrowUp\") { e.preventDefault(); prevSlide(); }\n        });\n\n        var isScrolling = false;\n        document.addEventListener(\"wheel\", function(e) {\n            if (isScrolling) return;\n            isScrolling = true;\n            if (e.deltaY > 0) nextSlide(); else prevSlide();\n            setTimeout(function() { isScrolling = false; }, 800);\n        }, { passive: true });\n\n        var touchStartY = 0;\n        document.addEventListener(\"touchstart\", function(e) { touchStartY = e.changedTouches[0].clientY; }, { passive: true });\n        document.addEventListener(\"touchend\", function(e) {\n            var diff = touchStartY - e.changedTouches[0].clientY;\n            if (Math.abs(diff) > 50) { if (diff > 0) nextSlide(); else prevSlide(); }\n        }, { passive: true });\n\n        function scaleSlides() {\n            document.querySelectorAll(\".slide\").forEach(function(slide) {\n                var container = slide.parentElement;\n                if (container) {\n                    var sc = Math.min(container.offsetWidth / 1280, container.offsetHeight / 720);\n                    slide.style.transform = \"scale(\" + sc + \")\";\n                }\n            });\n        }\n\n        initNavigation();\n        updateSlide();\n        window.addEventListener(\"resize\", scaleSlides);\n        window.addEventListener(\"load\", scaleSlides);\n    </script>\n</body>\n</html>"
}