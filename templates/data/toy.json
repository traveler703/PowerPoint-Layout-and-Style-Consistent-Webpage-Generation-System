{
  "template_id": "toy",
  "template_name": "Toy风",
  "description": "Toy风 - 活泼可爱的积木风格，适合儿童教育内容",
  "version": "1.0.0",
  "css_variables": {
    "color-primary": "#3B82F6",
    "color-secondary": "#FBBF24",
    "color-accent-red": "#EF4444",
    "color-accent-green": "#22C55E",
    "color-accent-purple": "#8B5CF6",
    "color-background": "#FFFBEB",
    "color-surface": "#FFFBEB",
    "color-text": "#333333",
    "color-text-muted": "#4B5563",
    "color-text-light": "#94a3b8",
    "color-card": "#FFFFFF",
    "color-cover-bg": "#1a1a2e",
    "font-body": "'Segoe UI', 'Microsoft YaHei', sans-serif",
    "font-heading": "'Segoe UI', 'Microsoft YaHei', sans-serif"
  },
  "page_types": {
    "cover": {
      "skeleton": "<div class=\"slide cover\"><div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div><div class=\"stars\"><div class=\"star\" style=\"width:3px;height:3px;top:20%;left:15%\"></div><div class=\"star\" style=\"width:2px;height:2px;top:30%;left:45%\"></div><div class=\"star\" style=\"width:4px;height:4px;top:15%;left:70%\"></div></div><div class=\"dino-bg\">🦖</div><div class=\"title-box\"><h1 class=\"main-title\">{{title}}</h1><p class=\"subtitle\">{{subtitle}}</p><div class=\"date-badge\"><i class=\"fa-solid fa-calendar\"></i> {{date_badge}}</div></div><div class=\"dino-group\"><span>🦖</span><span>🦑</span><span>🦖</span></div></div>",
      "placeholders": [
        "title",
        "subtitle",
        "date_badge"
      ]
    },
    "content": {
      "skeleton": "<div class=\"slide content\"><div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div><div class=\"deco-shape shape1\"></div><div class=\"deco-shape shape2\"></div><div class=\"deco-shape shape3\"></div><div class=\"deco-shape shape4\"></div><div class=\"page-title\"><i class=\"fa-solid fa-book-open\" style=\"margin-right:10px;color:#FBBF24\"></i>{{title}}</div><div class=\"page-content\">{{content}}</div></div>",
      "placeholders": [
        "title",
        "content"
      ]
    },
    "toc": {
      "skeleton": "<div class=\"slide toc\"><div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div><div class=\"page-title\"><i class=\"fa-solid fa-list\" style=\"margin-right:10px\"></i>{{title}}</div><div class=\"page-content\"><div class=\"toc-grid\">{{toc_items}}</div></div></div>",
      "placeholders": [
        "title",
        "toc_items"
      ]
    },
    "ending": {
      "skeleton": "<div class=\"slide ending\"><div class=\"slide-footer\"><span class=\"page-num\">{{page_number}}</span></div><div class=\"ending-content\"><span class=\"big-emoji\">🎉</span><h1>{{title}}</h1><p>{{message}}</p><div class=\"ending-dinos\"><span>🦖</span><span>🦑</span><span>🦖</span></div></div></div>",
      "placeholders": [
        "title",
        "message"
      ]
    }
  },
  "raw_html": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>PPT Template</title>\n    <script src=\"https://cdn.bootcdn.net/ajax/libs/Chart.js/4.4.1/chart.umd.js\"></script>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n    <style>\n        * { margin: 0; padding: 0; box-sizing: border-box; }\n        html { scroll-behavior: smooth; }\n        body { font-family: 'Segoe UI', 'Microsoft YaHei', sans-serif; overflow: hidden; height: 100vh; }\n\n        .slides-wrapper { width: 100vw; height: 100vh; overflow: hidden; position: relative; }\n        .slides-track { width: 100%; height: 100%; display: flex; transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1); }\n        .slide-container { width: 100vw; height: 100vh; flex-shrink: 0; display: flex; justify-content: center; align-items: center; }\n\n        .nav-dots { display: none; }\n        .nav-dot { width: 14px; height: 14px; border-radius: 50%; background: rgba(255,255,255,0.4); cursor: pointer; transition: all 0.3s; border: 2px solid transparent; }\n        .nav-dot:hover { background: rgba(255,255,255,0.7); transform: scale(1.2); }\n        .nav-dot.active { background: #FBBF24; border-color: white; transform: scale(1.3); }\n\n        .nav-arrows { position: absolute; bottom: 20px; right: 30px; display: flex; gap: 15px; z-index: 10; }\n        .nav-arrow { width: 40px; height: 40px; border-radius: 50%; background: rgba(0,0,0,0.4); backdrop-filter: blur(10px); border: 2px solid rgba(255,255,255,0.3); color: white; font-size: 16px; display: flex; justify-content: center; align-items: center; cursor: pointer; transition: all 0.3s; }\n        .nav-arrow:hover { background: rgba(255,255,255,0.4); transform: scale(1.1); }\n        .nav-arrow.disabled { opacity: 0.3; cursor: not-allowed; }\n\n        .page-indicator { position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); color: rgba(255,255,255,0.7); font-size: 14px; font-weight: 600; z-index: 10; }\n        .page-indicator .current { color: #FBBF24; font-size: 16px; }\n\n        .slide { width: 1280px; height: 720px; position: relative; overflow: hidden; transform-origin: center center; }\n        .slide-footer { position: absolute; bottom: 15px; left: 0; right: 0; text-align: center; z-index: 10; pointer-events: none; }\n        .slide-footer .page-num { color: rgba(255,255,255,0.6); font-size: 13px; font-weight: 500; }\n        \n        .slide.cover { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); }\n        .slide.cover .stars { position: absolute; width: 100%; height: 100%; }\n        .slide.cover .star { position: absolute; background: white; border-radius: 50%; animation: twinkle 2s infinite; }\n        @keyframes twinkle { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }\n        .slide.cover .dino-bg { position: absolute; font-size: 300px; opacity: 0.1; right: -50px; bottom: -50px; }\n        .slide.cover .title-box { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; z-index: 10; }\n        .slide.cover .main-title { font-size: 72px; font-weight: 900; color: white; text-shadow: 0 0 30px rgba(251, 191, 36, 0.5); margin-bottom: 20px; animation: glow 3s infinite; }\n        @keyframes glow { 0%, 100% { text-shadow: 0 0 30px rgba(251, 191, 36, 0.5); } 50% { text-shadow: 0 0 60px rgba(251, 191, 36, 0.8); } }\n        .slide.cover .subtitle { font-size: 28px; color: #94a3b8; margin-bottom: 40px; }\n        .slide.cover .date-badge { display: inline-block; background: linear-gradient(135deg, #FBBF24, #F59E0B); color: #1a1a2e; padding: 15px 40px; border-radius: 50px; font-size: 20px; font-weight: 700; }\n        .slide.cover .dino-group { position: absolute; bottom: 80px; left: 50%; transform: translateX(-50%); font-size: 60px; display: flex; gap: 30px; animation: walk 2s ease-in-out infinite; }\n        @keyframes walk { 0%, 100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(-10px); } }\n        \n        .slide.content { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); }\n        .deco-shape { position: absolute; border-radius: 50%; }\n        .shape1 { background-color: #3B82F6; width: 150px; height: 150px; top: -50px; right: 50px; opacity: 0.8; }\n        .shape2 { background-color: #FBBF24; width: 80px; height: 80px; top: 80px; right: -20px; opacity: 0.9; }\n        .shape3 { background-color: #EF4444; width: 200px; height: 200px; bottom: -100px; left: -80px; opacity: 0.7; }\n        .shape4 { background-color: #22C55E; width: 40px; height: 40px; bottom: 80px; left: 60px; }\n        \n        .page-title { position: absolute; top: 40px; left: 60px; background-color: #FBBF24; color: #1a1a2e; padding: 15px 30px; border-radius: 15px; font-size: 36px; font-weight: 900; display: inline-block; box-shadow: 0 4px 10px rgba(251, 191, 36, 0.4); z-index: 10; }\n        .page-content { position: absolute; top: 150px; left: 60px; right: 60px; bottom: 60px; padding: 20px; z-index: 5; font-size: 24px; line-height: 1.8; }\n        .page-content h2 { font-size: 32px; color: #FBBF24; margin-bottom: 20px; border-bottom: 4px solid #FBBF24; padding-bottom: 10px; display: inline-block; }\n        .page-content p { font-size: 22px; line-height: 1.6; color: #e2e8f0; margin-bottom: 20px; }\n        .page-content ul { list-style: none; }\n        .page-content ul li { font-size: 22px; color: #e2e8f0; margin-bottom: 15px; padding-left: 30px; position: relative; }\n        .page-content ul li::before { content: ''; position: absolute; left: 0; top: 8px; width: 16px; height: 16px; border-radius: 50%; background-color: #FBBF24; }\n        \n        .slide.toc { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); }\n        .slide.toc .page-title { background-color: #FBBF24; color: #1a1a2e; }\n        .toc-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 25px; margin-top: 30px; }\n        .toc-item { background: rgba(255,255,255,0.1); backdrop-filter: blur(10px); border-radius: 20px; padding: 25px; display: flex; align-items: center; gap: 20px; transition: all 0.3s; cursor: pointer; border: 1px solid rgba(255,255,255,0.15); }\n        .toc-item:hover { background: rgba(255,255,255,0.2); transform: translateX(10px); }\n        .toc-number { width: 60px; height: 60px; background: #FBBF24; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 28px; font-weight: 900; color: #1a1a2e; }\n        .toc-text h3 { font-size: 22px; color: white; margin-bottom: 5px; }\n        .toc-text p { font-size: 14px; color: #94a3b8; }\n        \n        .slide.compare { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); }\n        .compare-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; margin-top: 20px; }\n        .compare-card { background: rgba(255,255,255,0.95); border-radius: 25px; padding: 30px; text-align: center; box-shadow: 0 10px 40px rgba(0,0,0,0.3); transition: transform 0.3s; }\n        .compare-card:hover { transform: translateY(-10px); }\n        .compare-card h3 { font-size: 26px; color: #1a1a2e; margin-bottom: 10px; }\n        .compare-card .era { background: linear-gradient(135deg, #3B82F6, #60A5FA); color: white; padding: 8px 20px; border-radius: 20px; font-size: 14px; display: inline-block; margin-bottom: 15px; }\n        .compare-card ul { list-style: none; text-align: left; }\n        .compare-card ul li { font-size: 16px; color: #4B5563; margin-bottom: 8px; padding-left: 25px; position: relative; }\n        .compare-card ul li::before { content: '✓'; position: absolute; left: 0; color: #22C55E; font-weight: bold; }\n        \n        .slide.chart { background-color: #FFFBEB; }\n        .chart-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; height: 100%; }\n        .chart-left { display: flex; flex-direction: column; gap: 20px; }\n        .chart-box { background: white; border-radius: 20px; padding: 25px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); flex: 1; }\n        .chart-box h3 { font-size: 18px; color: #1F2937; margin-bottom: 15px; text-align: center; }\n        .fact-cards { display: flex; flex-direction: column; gap: 15px; }\n        .fact-card { background: linear-gradient(135deg, #DBEAFE, #BFDBFE); border-radius: 15px; padding: 20px; display: flex; align-items: center; gap: 15px; }\n        .fact-card .emoji { font-size: 40px; }\n        .fact-card .text h4 { font-size: 18px; color: #1E40AF; margin-bottom: 5px; }\n        .fact-card .text p { font-size: 14px; color: #3B82F6; }\n        \n        .slide.timeline { background: linear-gradient(135deg, #1e3a5f 0%, #0d1b2a 100%); }\n        .slide.timeline .page-title { background: linear-gradient(135deg, #FBBF24, #F59E0B); color: #1a1a2e; }\n        .timeline-container { position: relative; padding: 20px 0; }\n        .timeline-line { position: absolute; left: 50%; top: 0; bottom: 0; width: 6px; background: linear-gradient(to bottom, #FBBF24, #EF4444, #22C55E); border-radius: 3px; transform: translateX(-50%); }\n        .timeline-item { display: flex; align-items: center; margin-bottom: 30px; position: relative; }\n        .timeline-item:nth-child(odd) { flex-direction: row-reverse; }\n        .timeline-content { width: 45%; background: rgba(255,255,255,0.1); backdrop-filter: blur(10px); border-radius: 20px; padding: 25px; border: 1px solid rgba(255,255,255,0.2); }\n        .timeline-content h3 { font-size: 22px; color: #FBBF24; margin-bottom: 10px; }\n        .timeline-content p { font-size: 16px; color: #94a3b8; line-height: 1.6; }\n        .timeline-dot { position: absolute; left: 50%; transform: translateX(-50%); width: 30px; height: 30px; background: #FBBF24; border-radius: 50%; border: 5px solid #1e3a5f; z-index: 5; }\n        \n        .slide.qa { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); }\n        .slide.qa .page-title { background-color: #FBBF24; color: #1a1a2e; }\n        .qa-container { display: grid; grid-template-columns: repeat(2, 1fr); gap: 25px; margin-top: 20px; }\n        .qa-card { background: rgba(255,255,255,0.95); border-radius: 20px; padding: 25px; box-shadow: 0 5px 20px rgba(0,0,0,0.2); }\n        .qa-card .question { font-size: 18px; color: #1F2937; font-weight: 700; margin-bottom: 15px; display: flex; align-items: flex-start; gap: 10px; }\n        .qa-card .question::before { content: 'Q'; background: #EF4444; color: white; width: 28px; height: 28px; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 16px; flex-shrink: 0; }\n        .qa-card .answer { font-size: 16px; color: #4B5563; line-height: 1.6; padding-left: 38px; }\n        \n        .slide.ending { background: linear-gradient(135deg, #0c0c0c 0%, #1a1a2e 50%, #16213e 100%); }\n        .ending-content { text-align: center; padding-top: 100px; }\n        .ending-content .big-emoji { font-size: 120px; display: block; margin-bottom: 30px; animation: bounce 1s infinite; }\n        @keyframes bounce { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.1); } }\n        .ending-content h1 { font-size: 56px; color: white; margin-bottom: 20px; }\n        .ending-content p { font-size: 24px; color: #94a3b8; margin-bottom: 40px; }\n        .ending-dinos { display: flex; justify-content: center; gap: 40px; margin-top: 60px; font-size: 50px; }\n        .ending-dinos span { animation: walk2 2s ease-in-out infinite; }\n        .ending-dinos span:nth-child(2) { animation-delay: 0.3s; }\n        .ending-dinos span:nth-child(3) { animation-delay: 0.6s; }\n        @keyframes walk2 { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-15px); } }\n\n        .slide.cover .nav-dot, .slide.timeline .nav-dot, .slide.ending .nav-dot { background: rgba(255,255,255,0.4); }\n        .slide.cover .nav-dot.active, .slide.timeline .nav-dot.active, .slide.ending .nav-dot.active { background: #FBBF24; }\n    </style>\n</head>\n<body>\n    <div class=\"slides-wrapper\" id=\"slidesWrapper\">\n        <div class=\"slides-track\" id=\"slidesTrack\">\n            {{SLIDES_CONTENT}}\n        </div>\n    </div>\n\n    <div class=\"nav-dots\" id=\"navDots\"></div>\n    <div class=\"nav-arrows\">\n        <div class=\"nav-arrow\" id=\"prevBtn\" onclick=\"prevSlide()\">\n            <i class=\"fa-solid fa-chevron-left\"></i>\n        </div>\n        <div class=\"nav-arrow\" id=\"nextBtn\" onclick=\"nextSlide()\">\n            <i class=\"fa-solid fa-chevron-right\"></i>\n        </div>\n    </div>\n    <div class=\"page-indicator\" id=\"pageIndicator\" style=\"display:none\">\n        <span class=\"current\" id=\"currentPage\">1</span> / <span id=\"totalPages\">{{TOTAL_PAGES}}</span>\n    </div>\n\n    <script>\n        let currentSlide = 0;\n        let totalSlides = {{TOTAL_PAGES}};\n        const track = document.getElementById('slidesTrack');\n        const navDots = document.getElementById('navDots');\n        const currentPageEl = document.getElementById('currentPage');\n        const totalPagesEl = document.getElementById('totalPages');\n        const prevBtn = document.getElementById('prevBtn');\n        const nextBtn = document.getElementById('nextBtn');\n\n        function initNavigation() {\n            totalPagesEl.textContent = totalSlides;\n            for (let i = 0; i < totalSlides; i++) {\n                const dot = document.createElement('div');\n                dot.className = 'nav-dot' + (i === 0 ? ' active' : '');\n                dot.onclick = () => goToSlide(i);\n                navDots.appendChild(dot);\n            }\n        }\n\n        function goToSlide(index) {\n            currentSlide = Math.max(0, Math.min(index, totalSlides - 1));\n            updateSlide();\n        }\n\n        function nextSlide() {\n            if (currentSlide < totalSlides - 1) {\n                currentSlide++;\n                updateSlide();\n            }\n        }\n\n        function prevSlide() {\n            if (currentSlide > 0) {\n                currentSlide--;\n                updateSlide();\n            }\n        }\n\n        function updateSlide() {\n            track.style.transform = `translateX(-${currentSlide * 100}vw)`;\n            currentPageEl.textContent = currentSlide + 1;\n            document.querySelectorAll('.nav-dot').forEach((dot, i) => {\n                dot.classList.toggle('active', i === currentSlide);\n            });\n            prevBtn.classList.toggle('disabled', currentSlide === 0);\n            nextBtn.classList.toggle('disabled', currentSlide === totalSlides - 1);\n        }\n\n        document.addEventListener('keydown', (e) => {\n            if (e.key === 'ArrowRight' || e.key === 'ArrowDown' || e.key === ' ') {\n                e.preventDefault();\n                nextSlide();\n            } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {\n                e.preventDefault();\n                prevSlide();\n            }\n        });\n\n        let isScrolling = false;\n        document.addEventListener('wheel', (e) => {\n            if (isScrolling) return;\n            isScrolling = true;\n            if (e.deltaY > 0) nextSlide();\n            else prevSlide();\n            setTimeout(() => { isScrolling = false; }, 800);\n        }, { passive: true });\n\n        let touchStartY = 0;\n        document.addEventListener('touchstart', (e) => { touchStartY = e.touches[0].clientY; }, { passive: true });\n        document.addEventListener('touchend', (e) => {\n            const diff = touchStartY - e.changedTouches[0].clientY;\n            if (Math.abs(diff) > 50) {\n                if (diff > 0) nextSlide();\n                else prevSlide();\n            }\n        }, { passive: true });\n\n        function scaleSlides() {\n            document.querySelectorAll('.slide').forEach(slide => {\n                const container = slide.parentElement;\n                if (slide && container) {\n                    const scale = Math.min(container.offsetWidth / 1280, container.offsetHeight / 720);\n                    slide.style.transform = `scale(${scale})`;\n                }\n            });\n        }\n\n        initNavigation();\n        updateSlide();\n        window.addEventListener('resize', scaleSlides);\n        window.addEventListener('load', scaleSlides);\n    </script>\n</body>\n</html>",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "tags": [
    "Toy风",
    "儿童",
    "活泼",
    "可爱"
  ],
  "is_default": true
}